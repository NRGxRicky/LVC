---
/**
 * Footer.astro — Navy & Gold Design System
 *
 * Footer estilo Honimunn: logo textual, listas de destinos/compañía,
 * columna de contacto con 3 ciudades y redes sociales circulares.
 * Fondo #F0EEE9 (navy más oscuro) para contraste con el resto de secciones.
 */

const destinations = [
  { label: "Asia", href: "/universos/asia" },
  { label: "África", href: "/universos/africa" },
  { label: "Europa", href: "/universos/europa" },
  { label: "Medio Oriente", href: "/universos/medio-oriente" },
  { label: "Colecciones Premium", href: "/colecciones" },
];

const company = [
  { label: "Nuestra Filosofía", href: "/journey" },
  { label: "Journal de Viaje", href: "/journal" },
  { label: "Aviso Legal", href: "/aviso-de-privacidad" },
];


const currentYear = new Date().getFullYear();
---

<footer id="footer" class="w-full bg-[#F0EEE9]" aria-label="Pie de página">
  <!-- Cuerpo principal del footer -->
  <div class="max-w-[1920px] mx-auto px-8 md:px-12 pt-20 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Columna marca -->
      <div>
      <img
        src="/logo.png"
        alt="Luxury Voyage Collection"
        class="h-20 w-auto object-contain mb-5 logo-footer"
        width="80"
        height="80"
        loading="lazy"
      />
        <p
          class="font-body text-sm text-[#1C1713]/50 leading-relaxed mb-8 max-w-[240px]"
        >
          Cada detalle tiene un propósito. Cada decisión, una razón de ser.
        </p>
        <!-- Redes sociales — círculos como Honimunn -->
        <div class="flex gap-3" aria-label="Redes sociales">
          <a
            href="https://www.instagram.com/luxuryvoyagecollection/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 border border-[#D4AD65]/50 rounded-full flex items-center justify-center text-[#D4AD65] hover:bg-[#D4AD65] hover:text-white transition-all duration-300 text-xs font-bold tracking-tight"
          >
            IG
          </a>
          <a
            href="#"
            aria-label="TikTok"
            class="w-10 h-10 border border-[#D4AD65]/50 rounded-full flex items-center justify-center text-[#D4AD65] hover:bg-[#D4AD65] hover:text-white transition-all duration-300 text-xs font-bold"
          >
            TK
          </a>
        </div>
      </div>

      <!-- Columna destinos -->
      <nav aria-label="Destinos">
        <h4
          class="font-label uppercase tracking-[0.25em] text-xs text-[#D4AD65] mb-6"
        >
          Destinos
        </h4>
        <div class="flex flex-col gap-3">
          {
            destinations.map((link) => (
              <a
                href={link.href}
                class="font-body text-sm text-[#1C1713]/50 hover:text-[#D4AD65] transition-colors duration-300"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </nav>

      <!-- Columna compañía -->
      <nav aria-label="Compañía">
        <h4
          class="font-label uppercase tracking-[0.25em] text-xs text-[#D4AD65] mb-6"
        >
          Compañía
        </h4>
        <div class="flex flex-col gap-3">
          {
            company.map((link) => (
              <a
                href={link.href}
                class="font-body text-sm text-[#1C1713]/50 hover:text-[#D4AD65] transition-colors duration-300"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </nav>

      <!-- Columna contacto con oficinas — clave en Honimunn -->
      <div>
        <h4
          class="font-label uppercase tracking-[0.25em] text-xs text-[#D4AD65] mb-6"
        >
          Contacto
        </h4>
        <div class="flex flex-col gap-3">
          <a
            href="mailto:contacto@luxuryvoyageco.com"
            class="font-body text-sm text-[#1C1713]/50 hover:text-[#D4AD65] transition-colors duration-300 block"
          >
            contacto@luxuryvoyageco.com
          </a>
          <a
            href="tel:+525611877271"
            class="font-body text-sm text-[#1C1713]/50 hover:text-[#D4AD65] transition-colors duration-300 block"
          >
            +52 56 1187 7271
          </a>
          <span class="font-body text-sm text-[#1C1713]/50 block">
            Ciudad de México
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Barra inferior -->
  <div
    class="border-t border-white/5 px-8 md:px-12 py-6 max-w-[1920px] mx-auto flex flex-col md:flex-row justify-between items-center gap-3"
  >
    <p class="font-label text-xs text-[#1C1713]/30">
      © {currentYear} Luxury Voyage Collection · Todos los derechos reservados.
    </p>
    <div class="flex gap-6">
      <a
        href="/aviso-de-privacidad"
        class="font-label text-xs text-[#1C1713]/30 hover:text-[#D4AD65] transition-colors duration-300"
        >Privacidad</a
      >
      <a
        href="/terminos-y-condiciones"
        class="font-label text-xs text-[#1C1713]/30 hover:text-[#D4AD65] transition-colors duration-300"
        >Términos</a
      >
      <a
        href="#cookies"
        id="open-cookies"
        class="font-label text-xs text-[#1C1713]/30 hover:text-[#D4AD65] transition-colors duration-300"
        >Cookies</a
      >
    </div>
  </div>
</footer>

<style>
  .logo-footer {
    mix-blend-mode: multiply;
    filter: brightness(1.05);
  }
</style>
