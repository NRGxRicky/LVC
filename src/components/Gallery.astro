---
/**
 * Gallery.astro — Ivory & Espresso Design System
 *
 * Cuadrícula asimétrica editorial — "Curaduría Visual"
 * Tres columnas con offsets verticales para crear un ritmo narrativo.
 * Las imágenes tienen hover:scale para sensación de vida.
 */

interface GalleryItem {
  src: string;
  alt: string;
  title: string;
  caption: string;
  aspect: string; // Tailwind aspect class, e.g. "aspect-[3/4]"
  offset?: boolean; // mt-24 offset for middle column
}

const items: GalleryItem[] = [
  {
    src: "https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=1400&q=90",
    alt: "Arquitectura minimalista de interior de lujo con muros de mármol y luz natural dorada",
    title: "Texturas de Piedra",
    caption: "Materiales nobles seleccionados para su refugio.",
    aspect: "aspect-[3/4]",
  },
  {
    src: "https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=1400&q=90",
    alt: "Spa de lujo minimalista con bañera de piedra y luz de velas al atardecer",
    title: "Luz Cenital",
    caption: "El arte de habitar el espacio y el tiempo.",
    aspect: "aspect-square",
    offset: true,
  },
  {
    src: "https://lh3.googleusercontent.com/aida-public/AB6AXuCSqJ2385T9cXkHNPDcCuKiqw5VbcWkq39R2QPQDSeHE_bpeoEeIp_i9lNaPMS0ZL1ni9m6QRtbAJ8_n2K4b3lImgMjVoJfVTYLKMBt8ZdXzDB8wB8W5vH6CzDZWL00JrmfFQJqtJ9_5pqfZGJHF9Kb6Wz5k-tCG_Kwv1eKLSoTttE9_SyBk5X02EqFlGtfysN0XJrCSM6SGVElqImfRtw9e-DyjsgslFNPOQreikck0v0YXMC4uleD7xGLjjjw-VtLAcuYFA1Jpy0",
    alt: "Lodge de safari de lujo en Namibia al atardecer con dunas de arena doradas",
    title: "Horizontes Infinitos",
    caption: "Destinos más allá de lo convencional.",
    aspect: "aspect-[3/5]",
  },
];
---

<section
  id="galeria"
  class="py-32 px-12 bg-surface"
  aria-label="Curaduría Visual"
>
  <div class="max-w-[1920px] mx-auto">
    <!-- Section header -->
    <div class="flex justify-between items-end mb-24">
      <h2 class="font-headline text-5xl text-on-background">
        Curaduría Visual
      </h2>
      <!-- Decorative tonal line (not a separator border — design system compliant) -->
      <div
        class="hidden md:block w-1/3 h-[1px] bg-outline-variant/30"
        aria-hidden="true"
      >
      </div>
    </div>

    <!-- Asymmetric editorial grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
      {
        items.map((item, i) => (
          <article
            class={`flex flex-col gap-8 ${item.offset ? "mt-24" : ""}`}
            aria-label={item.title}
          >
            <div class={`${item.aspect} overflow-hidden`}>
              <img
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-1000"
                src={item.src}
                alt={item.alt}
                width="800"
                height="1000"
                loading="lazy"
              />
            </div>
            <h3 class="font-headline text-2xl italic text-on-background">
              {item.title}
            </h3>
            <p class="font-body text-sm text-secondary tracking-wide">
              {item.caption}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
