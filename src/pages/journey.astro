---
/**
 * journey.astro — Luxury Voyage Collection
 * Filosofía / Historia de la marca
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Luxury Voyage Collection — The Journey"
  description="Creemos que viajar es la forma más elevada de arte."
>
  <Navbar theme="light" />

  <main class="w-full bg-[#FAF9F6] pt-32 md:pt-40 pb-24">
    
    <!-- HEADER JOURNEY -->
    <section class="max-w-[1000px] mx-auto px-6 md:px-12 text-center mb-24">
      <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.2em] block mb-6">Nuestra Filosofía</span>
      <h1 class="font-heading text-fluid-h1 text-[#1C1713] mb-8 leading-tight">
        El viaje como una forma <span class="italic text-[#775A19]">de arte</span>
      </h1>
      <p class="font-sans text-fluid-p text-[#1C1713]/80 max-w-2xl mx-auto leading-relaxed">
        En Luxury Voyage Collection, no vendemos destinos; curamos momentos que desafían el tiempo. Creemos que la verdadera esencia del lujo radica en el silencio de un atardecer privado, en el diseño inmaculado de un refugio escondido y en el privilegio de la absoluta desconexión.
      </p>
    </section>

    <section class="w-full px-fluid-px mb-32 min-h-[60vh] overflow-hidden">
        <img 
            src="/images/journey_hero_1776311433257.png" 
            alt="The Journey - Filosofía"
            class="w-full h-full object-cover grayscale-[20%]"
        />
    </section>

    <!-- CONTENT MODULES -->
    <section class="max-w-[1200px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-32 mb-32">
        <div class="flex flex-col justify-center">
             <h2 class="font-heading text-fluid-h2 text-[#1C1713] mb-6">Curation is our core</h2>
            <p class="font-sans text-fluid-p text-[#1C1713]/70 leading-relaxed mb-6">
                Hemos viajado por el mundo para seleccionar personalmente cada propiedad, cada chef privado y cada experiencia que forma parte de nuestra colección. Rechazamos la estandarización y abrazamos lo singular. Cada propuesta está diseñada estrictamente a medida, respetando los gustos y tiempos de nuestros clientes más exigentes.
            </p>
            <div class="w-8 h-[1px] bg-[#D4AD65] mt-4"></div>
        </div>
        <div class="flex flex-col justify-center">
             <h2 class="font-heading text-fluid-h2 text-[#1C1713] mb-6">Invisible Service</h2>
            <p class="font-sans text-fluid-p text-[#1C1713]/70 leading-relaxed mb-6">
                El mejor servicio es aquel que no se ve, pero se siente. Nuestro equipo anticipa tus necesidades desde el momento en que sales de casa hasta tu regreso. Privacidad, seguridad y exclusividad guían cada una de nuestras decisiones logísticas.
            </p>
            <div class="w-8 h-[1px] bg-[#D4AD65] mt-4"></div>
        </div>
    </section>

  </main>

  <Footer />
</Layout>
