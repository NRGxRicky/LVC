<script>
  (() => {
    console.log("✦ LVC: Script de formulario de colección cargado!");

    const form = document.getElementById('collection-contact-form') as HTMLFormElement | null;
    const successModal = document.getElementById('success-modal');
    const successModalCard = document.getElementById('success-modal-card');
    const successModalMessage = document.getElementById('success-modal-message');
    const closeSuccessModalBtn = document.getElementById('close-success-modal');
    const submitBtn = document.getElementById('form-submit-btn');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      console.log("✦ LVC: Enviando consulta de colección...");

      const nombreInput = document.getElementById('form-nombre') as HTMLInputElement | null;
      const emailInput = document.getElementById('form-email') as HTMLInputElement | null;
      const whatsappInput = document.getElementById('form-whatsapp') as HTMLInputElement | null;
      const fechasInput = document.getElementById('form-fechas') as HTMLSelectElement | null;
      const viajerosInput = document.getElementById('form-viajeros') as HTMLSelectElement | null;
      const consideracionesInput = document.getElementById('form-consideraciones') as HTMLTextAreaElement | null;
      const coleccionInput = document.getElementById('form-coleccion') as HTMLInputElement | null;

      if (!nombreInput || !emailInput || !whatsappInput || !fechasInput || !viajerosInput || !consideracionesInput || !coleccionInput) {
        return;
      }

      const sanitize = (val: string) => val.replace(/</g, "&lt;").replace(/>/g, "&gt;");
      const nombre = sanitize(nombreInput.value.trim());
      const email = emailInput.value.trim();
      const whatsapp = whatsappInput.value.trim();
      const fechas = fechasInput.value;
      const viajeros = viajerosInput.value;
      const consideraciones = sanitize(consideracionesInput.value.trim()) || "Sin consideraciones adicionales";
      const coleccion = coleccionInput.value;

      const compiledMessage = `--- DETALLES DEL VIAJE (DESDE COLECCIÓN) ---
• Colección de interés: ${coleccion}
• Fechas de viaje: ${fechas}
• Viajeros: ${viajeros}

--- CONSIDERACIONES ESPECIALES ---
${consideraciones}`;

      const nameParts = nombre.split(" ");
      const firstname = nameParts[0] || "";
      const lastname = nameParts.slice(1).join(" ") || "";

      // Enviar a HubSpot
      const portalId = import.meta.env.PUBLIC_HUBSPOT_PORTAL_ID || "51495057";
      const formId = import.meta.env.PUBLIC_HUBSPOT_FORM_ID || "b25257b0-7b1a-43b8-a591-fa2853b7a244";
      const endpoint = `https://api.hsforms.com/submissions/v3/integration/submit/${portalId}/${formId}`;

      const payload = {
        fields: [
          { name: "firstname", value: firstname },
          { name: "lastname", value: lastname },
          { name: "email", value: email },
          { name: "phone", value: `+52 ${whatsapp}` },
          { name: "message", value: compiledMessage }
        ],
        context: {
          pageUri: window.location.href,
          pageName: document.title
        }
      };

      if (submitBtn) {
        submitBtn.setAttribute('disabled', 'true');
        submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      }

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          console.error("HubSpot submission failed:", await response.text());
        }
      } catch (error) {
        console.error("Error submitting to HubSpot:", error);
      } finally {
        if (submitBtn) {
          submitBtn.removeAttribute('disabled');
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      }

      // Mostrar modal de éxito
      if (successModalMessage) {
        successModalMessage.innerHTML = `Estimado(a) <strong>${nombre}</strong>, tu solicitud para la colección <strong>${coleccion}</strong> ha sido recibida con éxito. Un Diseñador de Viajes de Luxury Voyage Collection analizará tus preferencias y se pondrá en contacto contigo en un plazo máximo de 24 horas.`;
      }

      if (successModal && successModalCard) {
        successModal.classList.remove('opacity-0', 'pointer-events-none');
        successModal.classList.add('opacity-100');
        successModalCard.classList.remove('scale-95');
        successModalCard.classList.add('scale-100');
        document.body.style.overflow = "hidden";
      }
    });

    if (closeSuccessModalBtn && successModal && successModalCard) {
      closeSuccessModalBtn.addEventListener('click', () => {
        successModal.classList.remove('opacity-100');
        successModal.classList.add('opacity-0', 'pointer-events-none');
        successModalCard.classList.remove('scale-100');
        successModalCard.classList.add('scale-95');
        document.body.style.overflow = "";
        form.reset();
      });
    }
  })();
</script>

