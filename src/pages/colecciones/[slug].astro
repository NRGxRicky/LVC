                  <input 
                    type="email" 
                    name="email" 
                    id="form-email" 
                    placeholder="Escribe tu correo electrónico" 
                    required
                    class="w-full bg-[#FAF9F5] border border-[#1C1713]/10 px-4 py-3 rounded text-sm text-[#1C1713] focus:outline-none focus:border-[#775A19]/50 transition-colors"
                  />
                </div>
              </div>

              <!-- Fila 3: Fechas y Viajeros -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Fechas -->
                <div class="flex flex-col gap-2">
                  <label for="form-fechas" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Fechas Aproximadas de Viaje *</label>
                  <select 
                    name="fechas" 
                    id="form-fechas" 
                    required
                    class="w-full bg-[#FAF9F5] border border-[#1C1713]/10 px-4 py-3 rounded text-sm text-[#1C1713] focus:outline-none focus:border-[#775A19]/50 transition-colors cursor-pointer"
                  >
                    <option value="" disabled selected>Selecciona el mes</option>
                    <option value="enero">Enero 2026 / 2027</option>
                    <option value="febrero">Febrero 2026 / 2027</option>
                    <option value="marzo">Marzo 2026 / 2027</option>
                    <option value="abril">Abril 2026 / 2027</option>
                    <option value="mayo">Mayo 2026 / 2027</option>
                    <option value="junio">Junio 2026 / 2027</option>
                    <option value="julio">Julio 2026 / 2027</option>
                    <option value="agosto">Agosto 2026 / 2027</option>
                    <option value="septiembre">Septiembre 2026 / 2027</option>
                    <option value="octubre">Octubre 2026 / 2027</option>
                    <option value="noviembre">Noviembre 2026 / 2027</option>
                    <option value="diciembre">Diciembre 2026 / 2027</option>
                  </select>
                </div>

                <!-- Viajeros -->
                <div class="flex flex-col gap-2">
                  <label for="form-viajeros" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Número de Viajeros *</label>
                  <select 
                    name="viajeros" 
                    id="form-viajeros" 
                    required
                    class="w-full bg-[#FAF9F5] border border-[#1C1713]/10 px-4 py-3 rounded text-sm text-[#1C1713] focus:outline-none focus:border-[#775A19]/50 transition-colors cursor-pointer"
                  >
                    <option value="" disabled selected>Selecciona</option>
                    <option value="1">1 viajero</option>
                    <option value="2">2 viajeros</option>
                    <option value="3">3 viajeros</option>
                    <option value="4">4 viajeros</option>
                    <option value="5+">5+ viajeros</option>
                  </select>
                </div>
              </div>

              <!-- Campo 4: Consideraciones Especiales -->
              <div class="flex flex-col gap-2">
                <label for="form-consideraciones" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">¿Hay algo importante que debamos considerar?</label>
                <textarea 
                  name="consideraciones" 
                  id="form-consideraciones" 
                  placeholder="Cuéntanos aquí..." 
                  rows="4"
                  class="w-full bg-[#FAF9F5] border border-[#1C1713]/10 px-4 py-3 rounded text-sm text-[#1C1713] focus:outline-none focus:border-[#775A19]/50 transition-colors resize-none"
                ></textarea>
