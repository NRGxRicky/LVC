    <!-- SUCCESS MODAL (Para confirmación de envío a HubSpot) -->
    <div 
      id="success-modal" 
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-500 px-6"
    >
      <div 
        id="success-modal-card" 
        class="bg-[#EDE7D7] border border-[#775A19]/25 w-full max-w-lg p-10 text-center shadow-2xl scale-95 transition-transform duration-500 relative"
      >
        <div class="text-[#775A19] text-3xl mb-4">✦</div>
        <h2 class="font-heading text-xl md:text-2xl text-[#1C1713] uppercase tracking-wider mb-2">Diseño en Proceso</h2>
        <div class="w-12 h-[1px] bg-[#D4AD65] mx-auto mb-4"></div>
        <p id="success-modal-message" class="font-sans text-xs md:text-sm text-[#1C1713]/80 leading-relaxed mb-6">
          Tu solicitud ha sido recibida con éxito.
        </p>
        <button
          type="button"
          id="close-success-modal"
          class="inline-flex font-label text-[10px] uppercase tracking-widest font-bold text-[#FAF9F6] bg-[#1C1713] hover:bg-[#775A19] transition-all duration-300 px-8 py-3.5 cursor-pointer rounded-[2px]"
        >
          Cerrar y Regresar
        </button>
      </div>
    </div>

  </main>

  <Footer />
