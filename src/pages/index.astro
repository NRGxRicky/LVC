            <img src="/images/europa_card_1776310708089.png" alt="Europa" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
            <div class="absolute bottom-0 left-0 p-6 md:p-8">
