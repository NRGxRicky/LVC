---
/**
 * index.astro — Luxury Voyage Collection
 * HOME (Minimalista)
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import EditorialSplit from "../components/EditorialSplit.astro";

// Data for Continent Cards
const continentes = [
  {
    name: "ASIA",
    description: "Tradición, espiritualidad y modernidad en perfecta armonía.",
    image: "/images/asia_card_1776310696079.png",
    link: "/universos/asia"
  },
  {
    name: "EUROPA",
    description: "Elegancia atemporal, historia y experiencias que despiertan los sentidos.",
    image: "/images/europa_card_1776310708089.png",
    link: "/universos/europa"
  },
  {
    name: "ÁFRICA",
    description: "Naturaleza salvaje, paisajes extraordinarios y encuentros que transforman.",
    image: "/images/africa_card_1776310725568.png",
    link: "/universos/africa"
  },
  {
    name: "MEDIO ORIENTE",
    description: "Misterio, culturas y lujo en destinos que revelan lo extraordinario.",
    image: "/images/medio_oriente_card_1776310739207.png",
    link: "/universos/medio-oriente"
  }
];

// Data for Experiences
const experiencias = [
  {
    title: "CENA PRIVADA",
    desc: "Bajo las estrellas en lugares excepcionales.",
    image: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800&q=80"
  },
  {
    title: "HOSPEDAJES EXCLUSIVOS",
    desc: "Estancias únicas que elevan cada momento.",
    image: "https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=800&q=80"
  },
  {
    title: "EXPERIENCIAS GASTRONÓMICAS",
    desc: "Sabores locales, chefs privados y maridajes inolvidables.",
    image: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80"
  },
  {
    title: "AVENTURAS PRIVADAS",
    desc: "Actividades diseñadas según tus deseos.",
    image: "https://images.unsplash.com/photo-1548013146-72479768bada?w=800&q=80"
  }
];
---

<Layout
  title="Luxury Voyage Collection — Inicio"
  description="Donde viajar trasciende y se convierte en arte. Diseñamos la aventura más importante de tu vida."
>
  <Navbar />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HERO SECTION (CLASSIC ELEGANCE + KEN BURNS) -->
    <section class="relative w-full h-screen min-h-[600px] flex items-center justify-start overflow-hidden">
      <!-- Sistema Ken Burns inyectado directamente para robustez -->
      <style>
        @keyframes kenBurns {
          0% { transform: scale(1); }
          100% { transform: scale(1.1); }
        }
        .animate-ken-burns {
          animation: kenBurns 35s ease-in-out infinite alternate;
        }
      </style>
      
      <div class="absolute inset-0 z-0 bg-[#1C1713]">
        <img 
          src="/images/home_hero_1776310682545.png" 
          alt="Home Hero" 
          class="w-full h-full object-cover object-[70%_50%] md:object-center opacity-80 animate-ken-burns"
        />
        <!-- Degradados asimétricos para asegurar legibilidad total del texto del lado izquierdo -->
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent pointer-events-none"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713] via-transparent to-transparent pointer-events-none"></div>
      </div>
      
      <!-- Contenido Tipográfico Elegante alineado a la izquierda -->
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 flex flex-col items-start translate-y-4">
        <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl text-white max-w-2xl leading-[1.1] mb-6 reveal-up">
          Donde viajar trasciende y se convierte en <span class="text-[#D4AD65] italic font-serif">arte.</span>
        </h1>
        <p class="font-label text-xs md:text-sm uppercase tracking-[0.2em] text-white/80 max-w-md mb-10 leading-relaxed font-medium reveal-up reveal-delay-200">
          Experiencias diseñadas para quienes entienden el verdadero lujo.
        </p>
        
        <!-- Botón interactivo cinemático -->
        <a 
          href="/contacto" 
          class="group/cta relative overflow-hidden inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#1C1713] bg-[#D4AD65] px-8 py-4 transition-all duration-500 reveal-up reveal-delay-400"
        >
          <span class="absolute inset-0 bg-white transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
          <span class="relative z-10 flex items-center gap-3">
            Comienza a diseñar tu experiencia
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      </div>
    </section>
    
    <!-- 
      (VERSIÓN ORIGINAL RESPALDADA - TEXTO Y FOTO)
      <section class="relative w-full h-screen min-h-[600px] flex items-center justify-start overflow-hidden">
        <div class="absolute inset-0 z-0">
          <img src="/images/home_hero_1776310682545.png" alt="Pareja de lujo en balcón" class="w-full h-full object-cover object-[70%_50%] md:object-center" />
          <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-[#FAF9F6]"></div>
        </div>
        <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 pt-32 pb-24 flex flex-col items-start translate-y-12">
          <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl text-white max-w-2xl leading-[1.1] mb-6 reveal-up">Donde viajar trasciende y se convierte en <span class="text-[#D4AD65] italic font-serif">arte.</span></h1>
          <p class="font-label text-sm uppercase tracking-[0.2em] text-white/80 max-w-md mb-10 leading-relaxed font-medium reveal-up reveal-delay-100">Experiencias diseñadas para quienes entienden el verdadero lujo.</p>
          <a href="/contacto" class="group/cta relative overflow-hidden inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#1C1713] bg-[#D4AD65] px-8 py-4 transition-all duration-500 reveal-up reveal-delay-200">
            <span class="absolute inset-0 bg-white transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
            <span class="relative z-10 flex items-center gap-3">Comienza a diseñar tu experiencia<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></span>
          </a>
        </div>
      </section>
    -->

    <!-- FILOSOFIA EDITORIAL SECTION -->
    <EditorialSplit 
      imageSrc="/images/safari_split_media.jpg"
      imageAlt="Colección atemporal Safari, desde el amanecer hasta el anochecer."
      subtitle="La Filosofía de la Ausencia"
      headingText1="El verdadero lujo es el"
      accentWord="silencio"
      headingText2="absoluto."
      paragraph="En un mundo hiper-conectado, el aislamiento sublime es el bien más preciado. No vendemos destinos, curamos atmósferas donde el tiempo vuelve a pertenecerte. Diseñamos viajes donde la ausencia de distracciones es la máxima sofisticación."
      ctaText="Leer nuestro manifiesto"
      ctaLink="/contacto"
    />

    <!-- CONTINENTES SECTION -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-24 md:py-32">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8">
        <div class="reveal-up">
          <span class="font-label text-xs font-bold text-[#775A19] uppercase tracking-widest block mb-4">Colecciones del mundo</span>
          <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713]">El alma de cada <span class="italic">continente</span></h2>
        </div>
        <p class="font-sans text-sm text-[#1C1713]/70 max-w-sm leading-relaxed reveal-up reveal-delay-200">
          Explora universos únicos donde cada detalle ha sido cuidadosamente seleccionado.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 h-auto">
        {continentes.map((cont, i) => (
          <a href={cont.link} class={`group relative block w-full aspect-[3/4] overflow-hidden cursor-pointer reveal-up ${i > 0 ? "reveal-delay-" + (i * 100) : ""}`}>
            <img 
              src={cont.image} 
              alt={`Imagen de ${cont.name}`}
              class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713]/90 via-[#1C1713]/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>
            
            <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
              <h3 class="font-heading text-3xl text-white mb-3">{cont.name}</h3>
              <p class="font-sans text-xs text-white/80 leading-relaxed mb-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
                {cont.description}
              </p>
              <div class="w-6 h-[1px] bg-[#D4AD65] group-hover:w-12 transition-all duration-500"></div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- EXPERIENCIAS SECTION -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-24 md:py-32 border-t border-[#1C1713]/10">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8">
        <div class="reveal-up">
          <span class="font-label text-xs font-bold text-[#775A19] uppercase tracking-widest block mb-4">Momentos diseñados</span>
          <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713]">Experiencias a <span class="italic">medida</span></h2>
        </div>
        <p class="font-sans text-sm text-[#1C1713]/70 max-w-sm leading-relaxed reveal-up reveal-delay-200">
          Cada experiencia es única, creada exclusivamente para ti.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {experiencias.map((exp, i) => (
          <div class={`group cursor-pointer reveal-up ${i > 0 ? "reveal-delay-" + (i * 100) : ""}`}>
            <div class="w-full aspect-[4/3] overflow-hidden mb-6 relative">
              <img 
                src={exp.image} 
                alt={exp.title}
                class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]"
              />
              <div class="absolute inset-0 bg-[#1C1713]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <h3 class="font-heading text-xl text-[#1C1713] mb-2">{exp.title}</h3>
            <p class="font-sans text-sm text-[#1C1713]/70 mb-4 h-10">{exp.desc}</p>
            <div class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-[#775A19] mt-auto">
              <span class="w-4 h-[1px] bg-[#775A19]"></span>
              Explorar
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CALL TO ACTION (CTA) SECTION -->
    <section class="w-full bg-[#EFECE8] py-24 md:py-32 overflow-hidden">
      <div class="max-w-[1920px] mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center justify-between gap-12">
        <div class="max-w-xl reveal-up">
          <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] mb-6">Tu próximo viaje comienza aquí</h2>
          <p class="font-sans text-lg text-[#1C1713]/70 mb-10 leading-relaxed">
            Permítenos diseñar una experiencia a tu medida. Hablemos de tus ideas, preferencias y cómo podemos hacerlas realidad.
          </p>
          <a 
            href="/contacto" 
            class="group/cta relative overflow-hidden inline-flex items-center gap-4 font-label text-xs uppercase tracking-widest font-medium text-[#1C1713] border border-[#1C1713] px-8 py-4 w-max transition-all duration-500"
          >
            <span class="absolute inset-0 bg-[#1C1713] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
            <span class="relative z-10 flex items-center gap-4 group-hover/cta:text-[#FAF9F6] transition-colors duration-500">
              Hablemos de tu próximo viaje
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </a>
        </div>
        
        <div class="w-full max-w-md hidden md:block reveal-up reveal-delay-200">
          <!-- Detalles decorativos minimalistas -->
          <div class="aspect-square rounded-full border border-[#D4AD65]/30 relative mix-blend-multiply flex items-center justify-center">
             <div class="absolute inset-4 rounded-full border border-[#D4AD65]/10"></div>
             <img src="/logo.png" class="w-32 opacity-20 sepia" alt="" />
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
