              <img src="/images/medio_oriente_card_1776310739207.png" alt="Medio Oriente" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
