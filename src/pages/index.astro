        <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713] via-transparent to-transparent pointer-events-none z-10"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 flex flex-col items-center text-center translate-y-4">
