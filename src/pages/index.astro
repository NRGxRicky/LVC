---
/**
 * index.astro — Luxury Voyage Collection
 * HOME (Minimalista)
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import EditorialSplit from "../components/EditorialSplit.astro";

// Data for Continent Cards
const continentes = [
  {
    name: "ASIA",
    description: "Tradición, espiritualidad y modernidad en perfecta armonía.",
    image: "/images/asia_card_1776310696079.png",
    link: "/universos/asia"
  },
  {
    name: "EUROPA",
    description: "Elegancia atemporal, historia y experiencias que despiertan los sentidos.",
    image: "/images/europa_card_1776310708089.png",
    link: "/universos/europa"
  },
  {
    name: "ÁFRICA",
    description: "Naturaleza salvaje, paisajes extraordinarios y encuentros que transforman.",
    image: "/images/africa_card_1776310725568.png",
    link: "/universos/africa"
  },
  {
    name: "MEDIO ORIENTE",
    description: "Misterio, culturas y lujo en destinos que revelan lo extraordinario.",
    image: "/images/medio_oriente_card_1776310739207.png",
    link: "/universos/medio-oriente"
  }
];

// Data for Experiences
const experiencias = [
  {
    title: "ESTANCIAS SELECCIONADAS",
    desc: "Lugares que elevan cada momento.",
    image: "https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=800&q=80"
  },
  {
    title: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80"
  },
  {
    title: "EXPERIENCIAS DEL VIAJE",
    desc: "Momentos que marcan el recorrido.",
    image: "https://images.unsplash.com/photo-1548013146-72479768bada?w=800&q=80"
  }
];
---

<Layout
  title="Luxury Voyage Collection — Inicio"
  description="Donde viajar trasciende y se convierte en arte. Diseñamos la aventura más importante de tu vida."
>
  <Navbar />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- SECCIÓN 1: HERO -->
    <section class="relative w-full h-screen min-h-[600px] flex items-center justify-start overflow-hidden">
      <style>
        @keyframes kenBurns {
          0% { transform: scale(1); }
          100% { transform: scale(1.1); }
        }
        .animate-ken-burns {
          animation: kenBurns 35s ease-in-out infinite alternate;
        }
      </style>
      
      <div class="absolute inset-0 z-0 bg-[#1C1713]">
        <img src="/images/hero_carousel/slide1.jpg" alt="Safari Lujo" class="hero-slide absolute inset-0 w-full h-full object-cover object-[70%_50%] md:object-center opacity-80 transition-opacity duration-1000 ease-in-out animate-ken-burns" />
        <img src="/images/hero_carousel/slide2.jpg" alt="Safari Amanecer" class="hero-slide absolute inset-0 w-full h-full object-cover object-[70%_50%] md:object-center opacity-0 transition-opacity duration-1000 ease-in-out animate-ken-burns" />
        <img src="/images/hero_carousel/slide3.jpg" alt="Japón Lujo" class="hero-slide absolute inset-0 w-full h-full object-cover object-[70%_50%] md:object-center opacity-0 transition-opacity duration-1000 ease-in-out animate-ken-burns" />
        <img src="/images/hero_carousel/slide4.jpg" alt="Playa Lujo" class="hero-slide absolute inset-0 w-full h-full object-cover object-[70%_50%] md:object-center opacity-0 transition-opacity duration-1000 ease-in-out animate-ken-burns" />
        <img src="/images/hero_carousel/slide5.jpg" alt="Globo Lujo" class="hero-slide absolute inset-0 w-full h-full object-cover object-[70%_50%] md:object-center opacity-0 transition-opacity duration-1000 ease-in-out animate-ken-burns" />
        
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent pointer-events-none z-10"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713] via-transparent to-transparent pointer-events-none z-10"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 flex flex-col items-start translate-y-4">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white max-w-4xl leading-[1.1] mb-6 reveal-up">
          Donde viajar trasciende lo evidente y se transforma en <span class="text-[#D4AD65] italic font-serif">conexión.</span>
        </h1>
        <p class="font-label text-[10px] md:text-xs uppercase tracking-[0.2em] text-white/80 max-w-md mb-10 leading-relaxed font-medium reveal-up reveal-delay-200">
          Curamos viajes para ser vividos con intención.
        </p>
        
        <a 
          href="/contacto" 
          class="group/cta relative overflow-hidden inline-flex items-center gap-3 font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713] bg-[#E6C875] px-6 md:px-8 py-3 md:py-4 transition-all duration-500 reveal-up reveal-delay-400"
        >
          <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
          <span class="relative z-10 flex items-center gap-3">
            Diseña tu experiencia
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      </div>
    </section>

    <!-- SECCIÓN 2: LOGO + FILOSOFÍA CENTRADO -->
    <section class="w-full bg-[#FAF9F6] py-16 md:py-24 flex flex-col items-center justify-center text-center px-6">
      <div class="reveal-up mb-12">
        <img src="/images/logo-full.png" alt="Luxury Voyage Collection" class="w-64 md:w-80 h-auto opacity-90 mx-auto" />
      </div>
      <div class="reveal-up reveal-delay-200 max-w-3xl">
        <h2 class="font-heading text-3xl md:text-5xl text-[#1C1713] leading-tight mb-8 max-w-2xl mx-auto">
          Viajar también es una forma de <span class="text-[#D4AD65] italic">sentir el mundo</span>
        </h2>
        <p class="font-sans text-sm md:text-base text-[#1C1713]/70 leading-relaxed max-w-2xl mx-auto">
          Cada experiencia es concebida desde emociones, atmósferas y detalles diseñados para descubrir cada destino de manera distinta.
        </p>
        <div class="mt-12">
          <a href="/contacto" class="font-label text-xs uppercase tracking-widest text-[#775A19] border-b border-[#775A19] pb-1 hover:text-[#1C1713] hover:border-[#1C1713] transition-colors">
            Descubrir nuestra filosofía
          </a>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: UNIVERSOS (Cuadrícula asimétrica y Montserrat) -->
    <section class="w-full bg-[#1C1713] py-12 md:py-16 px-4 md:px-8">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-8 md:mb-12 reveal-up">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-widest block mb-4">Universos</span>
          <h2 class="font-heading text-4xl md:text-5xl text-white">El alma de cada <span class="italic text-[#D4AD65]">continente</span></h2>
        </div>

        <!-- Bento Grid Asimétrico -->
        <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-2 gap-4 h-auto md:h-[800px]">
          
          <!-- Asia (Destacado) -->
          <a href="/universos/asia" class="group relative block w-full h-[400px] md:h-full md:col-span-2 md:row-span-2 overflow-hidden cursor-pointer reveal-up">
            <img src="/images/asia_japon_card_1776311225534.png" alt="Asia" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
            <div class="absolute bottom-0 left-0 p-8 md:p-12">
              <h3 class="font-montserrat text-3xl md:text-5xl font-light text-white tracking-widest uppercase mb-3">Asia</h3>
              <p class="font-sans text-xs md:text-sm text-white/80 max-w-sm mb-4 leading-relaxed">Tradición, espiritualidad y modernidad en perfecta armonía.</p>
              <div class="flex items-center gap-3 text-[#D4AD65] group-hover:gap-5 transition-all duration-500">
                <span class="font-label text-[10px] uppercase tracking-widest">Explorar</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>

          <!-- Europa -->
          <a href="/universos/europa" class="group relative block w-full h-[300px] md:h-full overflow-hidden cursor-pointer reveal-up reveal-delay-100">
            <img src="/images/europa_card_1776310708089.png" alt="Europa" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
            <div class="absolute bottom-0 left-0 p-6 md:p-8">
              <h3 class="font-montserrat text-2xl md:text-3xl font-light text-white tracking-widest uppercase mb-2">Europa</h3>
              <p class="font-sans text-[10px] md:text-xs text-white/80 max-w-[200px] mb-3 leading-relaxed">Elegancia atemporal, historia y experiencias que despiertan los sentidos.</p>
              <div class="flex items-center gap-3 text-[#D4AD65] group-hover:gap-5 transition-all duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>

          <!-- África y Medio Oriente compartiendo la celda restante -->
          <div class="grid grid-cols-2 gap-4 h-[250px] md:h-full reveal-up reveal-delay-200">
            <a href="/universos/africa" class="group relative block w-full h-full overflow-hidden cursor-pointer">
              <img src="/images/africa_card_1776310725568.png" alt="África" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
              <div class="absolute bottom-0 left-0 p-4">
                <h3 class="font-montserrat text-lg md:text-xl font-light text-white tracking-widest uppercase mb-1">África</h3>
                <p class="font-sans text-[9px] md:text-[10px] text-white/70 max-w-[140px] mb-2 leading-relaxed hidden md:block">Naturaleza salvaje, paisajes extraordinarios y encuentros que transforman.</p>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D4AD65" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </a>
            <a href="/universos/medio-oriente" class="group relative block w-full h-full overflow-hidden cursor-pointer">
              <img src="/images/medio_oriente_card_1776310739207.png" alt="Medio Oriente" class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]" />
              <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors duration-500"></div>
              <div class="absolute bottom-0 left-0 p-4">
                <h3 class="font-montserrat text-lg md:text-xl font-light text-white tracking-widest uppercase mb-1">Medio<br>Oriente</h3>
                <p class="font-sans text-[9px] md:text-[10px] text-white/70 max-w-[140px] mb-2 leading-relaxed hidden md:block">Misterio, cultura y lujo en destinos que revelan lo extraordinario.</p>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D4AD65" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 4: EXPERIENCIAS (Generales) -->
    <section class="w-full bg-[#FAF9F6] max-w-[1920px] mx-auto px-6 md:px-12 py-12 md:py-16">
      <div class="text-center mb-8 md:mb-12 reveal-up">
        <span class="font-label text-[10px] md:text-xs font-bold text-[#775A19] uppercase tracking-widest block mb-4">Momentos del viaje</span>
        <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713]">Donde el viaje cobra <span class="italic text-[#D4AD65]">sentido</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 max-w-6xl mx-auto">
        {experiencias.map((exp, i) => (
          <div class={`group cursor-pointer reveal-up ${i > 0 ? "reveal-delay-" + (i * 100) : ""}`}>
            <div class="w-full aspect-[4/3] overflow-hidden mb-6 relative">
              <img 
                src={exp.image} 
                alt={exp.title}
                class="w-full h-full object-cover transition-transform duration-[4000ms] ease-out group-hover:scale-[1.08]"
              />
              <div class="absolute inset-0 bg-[#1C1713]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>
            <h3 class="font-heading text-lg md:text-xl text-[#1C1713] mb-2">{exp.title}</h3>
            <p class="font-sans text-xs md:text-sm text-[#1C1713]/70 mb-4 h-auto md:h-10">{exp.desc}</p>
          </div>
        ))}
      </div>
      
      <!-- CTA Integrado -->
      <div class="mt-24 text-center reveal-up">
        <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] mb-8">Cada viaje comienza con una decisión.</h2>
        <a 
          href="/contacto" 
          class="group/cta relative overflow-hidden inline-flex items-center gap-4 font-label text-[10px] md:text-xs uppercase tracking-widest font-medium text-[#FAF9F6] bg-[#1C1713] px-8 py-4 transition-all duration-500"
        >
          <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
          <span class="relative z-10 flex items-center gap-4 transition-colors duration-500">
            Diseña tu experiencia
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  (function() {
    const slides = document.querySelectorAll('.hero-slide');
    if (!slides || slides.length <= 1) return;
    
    let current = 0;

    // Set initial z-index stacking
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.zIndex = i === 0 ? '2' : '1';
    });

    setInterval(() => {
      const prev = current;
      current = (current + 1) % slides.length;

      // New slide comes on top and fades in
      (slides[current] as HTMLElement).style.zIndex = '3';
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-80');

      // After transition completes, hide old slide
      setTimeout(() => {
        slides[prev].classList.remove('opacity-80');
        slides[prev].classList.add('opacity-0');
        (slides[prev] as HTMLElement).style.zIndex = '1';
        (slides[current] as HTMLElement).style.zIndex = '2';
      }, 1200);
    }, 5000);
  })();
</script>
