        ))}
      </div>
      
      <!-- CTA Integrado -->
      <div class="mt-24 text-center reveal-up">
        <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] mb-8">Cada viaje comienza con una decisión.</h2>
        <a 
          href="/contacto" 
          class="group/cta relative overflow-hidden inline-flex items-center gap-4 font-label text-[10px] md:text-xs uppercase tracking-widest font-medium text-[#FAF9F6] bg-[#1C1713] px-8 py-4 transition-all duration-500"
        >
          <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
          <span class="relative z-10 flex items-center gap-4 transition-colors duration-500">
            Diseña tu experiencia
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  // Script para el carrusel 3D de folletos
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.carousel-item');
    if (!items.length) return;
    
    let currentIndex = 0;
    const totalItems = items.length;
    let autoRotateInterval;
    
    function updateCarousel() {
      items.forEach((item, i) => {
        // Calcular la distancia desde el índice actual
        let diff = i - currentIndex;
        // Ajustar para que el array sea circular
        if (diff < -1) diff += totalItems;
        if (diff > 1) diff -= totalItems;
        
        if (diff === 0) {
          // Elemento central (Activo)
          item.style.transform = 'translateX(0) scale(1) translateZ(80px) rotateY(0deg)';
          item.style.zIndex = '30';
          item.style.opacity = '1';
          item.style.filter = 'brightness(1)';
        } else if (diff === 1) {
          // Elemento a la derecha
          item.style.transform = 'translateX(55%) scale(0.85) translateZ(-80px) rotateY(-15deg)';
          item.style.zIndex = '20';
          item.style.opacity = '0.7';
          item.style.filter = 'brightness(0.8)';
        } else if (diff === -1) {
          // Elemento a la izquierda
          item.style.transform = 'translateX(-55%) scale(0.85) translateZ(-80px) rotateY(15deg)';
          item.style.zIndex = '20';
          item.style.opacity = '0.7';
          item.style.filter = 'brightness(0.8)';
        }
      });
    }
    
    function startAutoRotate() {
        autoRotateInterval = setInterval(() => {
            currentIndex = (currentIndex + 1) % totalItems;
            updateCarousel();
        }, 4000);
    }
    
    function resetAutoRotate() {
        clearInterval(autoRotateInterval);
        startAutoRotate();
    }
    
    updateCarousel();
    startAutoRotate();
    
    // Permitir clic para rotar
    items.forEach((item, i) => {
      item.addEventListener('click', () => {
        currentIndex = i;
        updateCarousel();
        resetAutoRotate(); // Reiniciar el temporizador al hacer clic
      });
    });
  });
</script>

<script>
  (function() {
    const slides = document.querySelectorAll('.hero-slide');
    if (!slides || slides.length <= 1) return;
    
    let current = 0;

    // Set initial z-index stacking
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.zIndex = i === 0 ? '2' : '1';
    });

    setInterval(() => {
      const prev = current;
      current = (current + 1) % slides.length;

      // New slide comes on top and fades in
      (slides[current] as HTMLElement).style.zIndex = '3';
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-80');

      // After transition completes, hide old slide
      setTimeout(() => {
        slides[prev].classList.remove('opacity-80');
        slides[prev].classList.add('opacity-0');
        (slides[prev] as HTMLElement).style.zIndex = '1';
        (slides[current] as HTMLElement).style.zIndex = '2';
      }, 1200);
    }, 5000);
  })();
</script>
