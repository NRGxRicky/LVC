---
/**
 * medio-oriente.astro — Universo Medio Oriente
 */

import UniversoLayout from "../../layouts/UniversoLayout.astro";

const lugares = [
  {
    name: "EMIRATOS ÁRABES UNIDOS",
    desc: "Visión, exclusividad y lujo llevado al límite.",
    image: "https://images.unsplash.com/photo-1512453979798-5ea266f8880c?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "ARABIA SAUDITA",
    desc: "Tradición, grandeza y una nueva forma de entender el lujo.",
    image: "https://images.unsplash.com/photo-1663900108404-a05e8bf82cda?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  },
  {
    name: "OMÁN",
    desc: "Autenticidad, serenidad y lujo profundamente contemplativo.",
    image: "https://images.unsplash.com/photo-1763544376867-7ad4e9e366cc?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  },
  {
    name: "CATAR",
    desc: "Sofisticación, diseño y elegancia perfectly equilibrada.",
    image: "https://images.unsplash.com/photo-1669815007479-494b3b51c2c3?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  }
];

const experiencias = [
  {
    name: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://garage-web.luxuryvoyageco.com/images/oriente_mid.png"
  },
  {
    name: "ESTANCIAS SELECCIONADAS",
    desc: "Espacios elegidos por lo que hacen sentir.",
    image: "https://garage-web.luxuryvoyageco.com/images/oriente_dubai.png"
  },
  {
    name: "INMERSIONES",
    desc: "Escenarios que transforman la forma de vivir cada destino.",
    image: "https://garage-web.luxuryvoyageco.com/images/asia_cena_1776311284263.png"
  }
];
---

<UniversoLayout
  title="Universo Medio Oriente — Luxury Voyage Collection"
  description="Donde el lujo moderno se alza sobre dunas milenarias."
  slug="medio-oriente"
  heroTitle="MEDIO ORIENTE"
  heroImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/medio_oriente.webp"
  heroImageMobile="https://garage-web.luxuryvoyageco.com/images/hero_carousel/medio_oriente_mobile.webp"
  heroDesc="Una visión marcada por lo extraordinario."
  splitImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/medio_oriente.webp"
  lugares={lugares}
  experiencias={experiencias}
>
  <!-- Philosophy Section -->
  <section class="w-full bg-[#EDE7D7] border-t border-[#1C1713]/10 overflow-hidden">
    <div class="max-w-[1920px] mx-auto flex flex-col lg:flex-row items-stretch min-h-[500px]">
      
      <!-- Left Image Column -->
      <div class="w-full lg:w-[35%] xl:w-[38%] min-h-[350px] lg:min-h-0 relative overflow-hidden">
        <img 
          src="/medio_oriente_philosophy.png" 
          alt="Lujo milenario en Medio Oriente" 
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Text Content and Pillars Columns -->
      <div class="w-full lg:w-[65%] xl:w-[62%] grid grid-cols-1 md:grid-cols-2">
        
        <!-- Middle Column: Description -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col justify-between min-h-[420px] md:min-h-0">
          <div class="flex flex-col gap-6">
            <div>
              <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">EL ALMA DE MEDIO ORIENTE</span>
              <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
              
              <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] leading-[1.25]">
                Lo que hace de <span class="text-[#D4AD65] italic font-serif">Medio<br />Oriente</span> una experiencia distinta.
              </h2>
            </div>
            
            <div class="flex flex-col gap-4 font-sans text-sm text-[#1C1713]/70 leading-relaxed">
              <p>
                Medio Oriente no se define únicamente por su historia, sus paisajes o su riqueza cultural.
              </p>
              <p>
                Lo que une a sus destinos es una herencia profunda, donde la hospitalidad, la espiritualidad y la búsqueda de la belleza han dado forma a civilizaciones extraordinarias.
              </p>
              <p>
                Es una región donde lo ancestral y lo contemporáneo conviven en perfecta armonía, creando experiencias que inspiran, transforman y permanecen en la memoria mucho después del viaje.
              </p>
            </div>
          </div>
          
          <div class="mt-8">
            <a 
              href="/journey" 
              class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
            >
              NUESTRA FORMA DE ENTENDER EL VIAJE &nbsp;&rarr;
            </a>
          </div>
        </div>

        <!-- Right Column: Pillars -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col gap-8 justify-center border-t md:border-t-0 md:border-l border-[#1C1713]/10">
          
          <!-- Pillar 1 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="12" cy="12" r="2.5" />
              <path d="M12 9.5c0-1.5-1-3-2-3s-2 1.5-2 3 1 3 2 3h2v-3z" />
              <path d="M12 9.5c0-1.5 1-3 2-3s2 1.5 2 3-1 3-2 3h-2v-3z" />
              <path d="M12 14.5c0 1.5-1 3-2 3s-2-1.5-2-3 1-3 2-3h2v3z" />
              <path d="M12 14.5c0 1.5 1 3 2 3s2-1.5 2-3-1-3-2-3h-2v3z" />
              <path d="M9.5 12c-1.5 0-3-1-3-2s1.5-2 3-2 3 1 3 2v2H9.5z" />
              <path d="M14.5 12c1.5 0 3-1 3-2s-1.5-2-3-2-3 1-3 2v2h3z" />
              <path d="M9.5 12c-1.5 0-3 1-3 2s1.5 2 3 2 3-1 3-2v-2H9.5z" />
              <path d="M14.5 12c1.5 0 3 1 3 2s-1.5 2-3 2-3-1-3-2v-2h3z" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">GRANDEZA QUE TRASCIENDE</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Una expresión de monumentalidad, diseño y visión que ha dejado huella en el mundo.</p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
              <path d="M4 8c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 12c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 16c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">HERENCIA VIVA</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Tradiciones, espiritualidad y valores que continúan presentes en la vida cotidiana.</p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 20V8a7 7 0 0 1 14 0v12" />
              <path d="M9 20v-4a3 3 0 0 1 6 0v4" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">HOSPITALIDAD EXCEPCIONAL</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Una cultura que recibe con generosidad y convierte cada encuentro en una experiencia significativa.</p>
            </div>
          </div>

          <!-- Pillar 4 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 12l10 10 10-10L12 2z" />
              <path d="M12 2v20" />
              <path d="M2 12h20" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">CONTRASTES QUE ENRIQUECEN</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Donde lo ancestral y lo moderno se encuentran para crear destinos únicos y fascinantes.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</UniversoLayout>
