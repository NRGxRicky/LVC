---
/**
 * medio-oriente.astro — Universo Medio Oriente
 */

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
  title="Universo Medio Oriente — Luxury Voyage Collection"
  description="Misterio, culturas milenarias y lujo en destinos que revelan lo extraordinario."
>
  <Navbar />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HERO MEDIO ORIENTE -->
    <section class="relative w-full h-screen min-h-[700px] flex items-center justify-start overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src="/images/medio_oriente_card_1776310739207.png" 
          alt="Paisaje de Medio Oriente" 
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#1C1713]/80 via-[#1C1713]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-50% to-[#FAF9F6]"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 md:pl-24 pt-32 pb-24 flex flex-col items-start h-full justify-center">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em]">Universo</span>
          <div class="w-12 h-[1px] bg-[#D4AD65]"></div>
        </div>
        <h1 class="font-heading text-6xl md:text-8xl lg:text-9xl text-white mb-8 tracking-wide">MEDIO<br/>ORIENTE</h1>
        <p class="font-sans text-lg text-white/90 max-w-sm mb-12 leading-relaxed">
          Misterio, culturas milenarias y lujo en destinos que revelan <span class="text-[#D4AD65] italic">lo extraordinario.</span>
        </p>
        <a 
          href="/contacto" 
          class="flex items-center gap-3 font-label text-xs uppercase tracking-widest text-white/80 hover:text-[#D4AD65] transition-colors duration-300 group"
        >
          Diseña tu experiencia
          <div class="w-12 h-[1px] bg-white/30 group-hover:bg-[#D4AD65] group-hover:w-16 transition-all duration-300"></div>
        </a>
      </div>
    </section>

    <!-- CONTENT PLACEHOLDER -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-16 text-center">
        <h2 class="font-heading text-4xl text-[#1C1713] mb-6">Descubre lo eterno</h2>
        <p class="font-sans text-[#1C1713]/70 max-w-lg mx-auto">
            (Estructura base lista para expandirse usando como componente el layout de Asia).
        </p>
    </section>

  </main>
  <Footer />
</Layout>
