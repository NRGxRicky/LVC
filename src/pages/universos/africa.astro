---
/**
 * africa.astro — Universo África
 */

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

const lugares = [
  {
    name: "LUGAR 1",
    desc: "Descripción de este lugar en África.",
    image: "https://images.unsplash.com/photo-1516426122078-c23e76319801?w=800&q=80"
  },
  {
    name: "LUGAR 2",
    desc: "Descripción de este lugar en África.",
    image: "https://images.unsplash.com/photo-1547471080-7bc2caa7ca0a?w=800&q=80"
  },
  {
    name: "LUGAR 3",
    desc: "Descripción de este lugar en África.",
    image: "https://images.unsplash.com/photo-1518709268805-4e9042af9f23?w=800&q=80"
  }
];

const experiencias = [
  {
    title: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&q=80"
  },
  {
    title: "ESTANCIAS SELECCIONADAS",
    desc: "Lugares que elevan cada momento.",
    image: "https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=800&q=80"
  },
  {
    title: "EXPERIENCIAS DEL VIAJE",
    desc: "Momentos que marcan el recorrido.",
    image: "https://images.unsplash.com/photo-1548013146-72479768bada?w=800&q=80"
  }
];
---

<Layout
  title="Universo África — Luxury Voyage Collection"
  description="Naturaleza salvaje, paisajes extraordinarios y encuentros que transforman."
>
  <Navbar />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HERO ÁFRICA -->
    <section class="relative w-full h-screen min-h-[700px] flex items-center justify-start overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src="/images/africa_card_1776310725568.png" 
          alt="Paisaje de África" 
          class="w-full h-full object-cover object-top"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#1C1713]/80 via-[#1C1713]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-50% to-[#FAF9F6]"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 md:pl-24 pt-32 pb-24 flex flex-col items-start h-full justify-center">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em]">Universo</span>
          <div class="w-12 h-[1px] bg-[#D4AD65]"></div>
        </div>
        <h1 class="font-heading text-6xl md:text-8xl lg:text-9xl text-white mb-8 tracking-wide">ÁFRICA</h1>
        <p class="font-sans text-lg text-white/90 max-w-sm mb-12 leading-relaxed">
          Naturaleza salvaje, paisajes extraordinarios y encuentros que <span class="text-[#D4AD65] italic">transforman.</span>
        </p>
        <a 
          href="/contacto" 
          class="flex items-center gap-3 font-label text-xs uppercase tracking-widest text-white/80 hover:text-[#D4AD65] transition-colors duration-300 group"
        >
          Diseña tu experiencia
          <div class="w-12 h-[1px] bg-white/30 group-hover:bg-[#D4AD65] group-hover:w-16 transition-all duration-300"></div>
        </a>
      </div>
    </section>

    <!-- LUGARES QUE INSPIRAN -->
    <section id="lugares" class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-12 md:py-16">
        <div class="text-center mb-12">
            <span class="font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest block mb-4">Escenarios</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-tight">Donde la esencia se vuelve <span class="italic text-[#D4AD65]">lugar</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
                {lugares.map((lugar) => (
                    <div class="group relative block w-full aspect-[2/3] overflow-hidden bg-[#1C1713]">
                        <img 
                          src={lugar.image} 
                          alt={lugar.name}
                          class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-80 group-hover:opacity-100"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713] via-[#1C1713]/20 to-transparent opacity-90"></div>
                        
                        <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col">
                          <h3 class="font-heading text-2xl text-white mb-3 tracking-wide">{lugar.name}</h3>
                          <p class="font-sans text-xs text-white/70 leading-relaxed mb-6">
                            {lugar.desc}
                          </p>
                          <div class="flex items-center gap-4 group-hover:gap-6 transition-all duration-300 text-white/50 group-hover:text-[#D4AD65]">
                             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                          </div>
                        </div>
                    </div>
                ))}
        </div>
    </section>

    <!-- EXPERIENCIAS QUE TRANSFORMAN -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-12 md:py-16">
        <div class="text-center mb-12">
            <span class="font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest block mb-4">Momentos del viaje</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-tight">Donde el viaje cobra <span class="italic text-[#D4AD65]">sentido</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
            {experiencias.map(exp => (
                <div class="group relative block w-full aspect-[4/3] overflow-hidden bg-[#1C1713]">
                    <img 
                        src={exp.image} 
                        alt={exp.title}
                        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-80 group-hover:opacity-100"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713] via-[#1C1713]/40 to-transparent opacity-90"></div>
                    
                    <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col">
                        <h3 class="font-heading text-xl text-white mb-2 uppercase tracking-wide">{exp.title}</h3>
                        <p class="font-sans text-xs text-white/70 leading-relaxed mb-6">
                            {exp.desc}
                        </p>
                        <div class="flex items-center gap-4 group-hover:gap-6 transition-all duration-300 text-white/50 group-hover:text-[#D4AD65]">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </section>

  </main>
  <Footer />
</Layout>
