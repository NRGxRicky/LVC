---
/**
 * africa.astro — Universo África
 */

import UniversoLayout from "../../layouts/UniversoLayout.astro";

const lugares = [
  {
    name: "SUDÁFRICA",
    desc: "Contrastes intensos y una belleza imposible de domesticar.",
    image: "https://images.unsplash.com/photo-1580618672591-eb180b1a973f?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "KENIA",
    desc: "Libertad, inmensidad y emoción en estado puro.",
    image: "https://images.unsplash.com/photo-1516426122078-c23e76319801?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "TANZANIA",
    desc: "Naturaleza salvaje y momentos que cambian la perspectiva.",
    image: "https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "MARRUECOS",
    desc: "Misterio, sensibilidad y una riqueza que despierta los sentidos.",
    image: "https://images.unsplash.com/photo-1570133435807-5feefeb2d196?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  },
  {
    name: "BOTSUANA",
    desc: "Exclusividad, silencio y naturaleza en su forma más pura.",
    image: "https://images.unsplash.com/photo-1577971132997-c10be9372519?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  },
  {
    name: "EGIPTO",
    desc: "Grandeza, historia y asombro frente a lo eterno.",
    image: "https://images.unsplash.com/photo-1503177119275-0aa32b3a9368?q=80&w=1000&auto=format&fit=crop"
  }
];

const experiencias = [
  {
    name: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://garage-web.luxuryvoyageco.com/images/africa_safari.png"
  },
  {
    name: "ESTANCIAS SELECCIONADAS",
    desc: "Espacios elegidos por lo que hacen sentir.",
    image: "https://garage-web.luxuryvoyageco.com/images/africa_lodge.png"
  },
  {
    name: "INMERSIONES",
    desc: "Escenarios que transforman la forma de vivir cada destino.",
    image: "https://garage-web.luxuryvoyageco.com/images/africa_cena.png"
  }
];
---

<UniversoLayout
  title="Universo África — Luxury Voyage Collection"
  description="Donde la naturaleza salvaje revela la esencia misma de la vida."
  slug="africa"
  heroTitle="ÁFRICA"
  heroImage="https://garage-web.luxuryvoyageco.com/images/africa_card_1776310725568.png"
  heroDesc="El arte de vivir aquello que transforma."
  splitImage="https://garage-web.luxuryvoyageco.com/images/safari_split_media.jpg"
  lugares={lugares}
  experiencias={experiencias}
>
  <!-- Philosophy Section -->
  <section class="w-full bg-[#EDE7D7] border-t border-[#1C1713]/10 overflow-hidden">
    <div class="max-w-[1920px] mx-auto flex flex-col lg:flex-row items-stretch min-h-[500px]">
      
      <!-- Left Image Column -->
      <div class="w-full lg:w-[35%] xl:w-[38%] min-h-[350px] lg:min-h-0 relative overflow-hidden">
        <img 
          src="/africa_philosophy.png" 
          alt="Naturaleza salvaje en África" 
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Text Content and Pillars Columns -->
      <div class="w-full lg:w-[65%] xl:w-[62%] grid grid-cols-1 md:grid-cols-2">
        
        <!-- Middle Column: Description -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col justify-between min-h-[420px] md:min-h-0">
          <div class="flex flex-col gap-6">
            <div>
              <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">EL ALMA DE ÁFRICA</span>
              <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
              
              <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] leading-[1.25]">
                Lo que hace de <span class="text-[#D4AD65] italic font-serif">África</span><br />
                una experiencia distinta.
              </h2>
            </div>
            
            <div class="flex flex-col gap-4 font-sans text-sm text-[#1C1713]/70 leading-relaxed">
              <p>
                África no se define únicamente por sus paisajes, su vida salvaje o la inmensidad de sus territorios.
              </p>
              <p>
                Lo que une a sus destinos es una conexión profunda con la naturaleza, el sentido de pertenencia a la tierra y una forma de vivir donde el tiempo parece recuperar su verdadera dimensión.
              </p>
              <p>
                Es una región donde la grandeza no se construye, se contempla; donde cada encuentro, cada horizonte y cada silencio recuerdan lo extraordinario que puede ser el mundo.
              </p>
            </div>
          </div>
          
          <div class="mt-8">
            <a 
              href="/journey" 
              class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
            >
              NUESTRA FORMA DE ENTENDER EL VIAJE &nbsp;&rarr;
            </a>
          </div>
        </div>

        <!-- Right Column: Pillars -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col gap-8 justify-center border-t md:border-t-0 md:border-l border-[#1C1713]/10">
          
          <!-- Pillar 1 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="12" cy="12" r="2.5" />
              <path d="M12 9.5c0-1.5-1-3-2-3s-2 1.5-2 3 1 3 2 3h2v-3z" />
              <path d="M12 9.5c0-1.5 1-3 2-3s2 1.5 2 3-1 3-2 3h-2v-3z" />
              <path d="M12 14.5c0 1.5-1 3-2 3s-2-1.5-2-3 1-3 2-3h2v3z" />
              <path d="M12 14.5c0 1.5 1 3 2 3s2-1.5 2-3-1-3-2-3h-2v3z" />
              <path d="M9.5 12c-1.5 0-3-1-3-2s1.5-2 3-2 3 1 3 2v2H9.5z" />
              <path d="M14.5 12c1.5 0 3-1 3-2s-1.5-2-3-2-3 1-3 2v2h3z" />
              <path d="M9.5 12c-1.5 0-3-1-3-2s1.5 2 3 2 3-1 3-2v-2H9.5z" />
              <path d="M14.5 12c1.5 0 3 1 3 2s-1.5 2-3 2-3-1-3-2v-2h3z" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">LA FUERZA DE LO ESENCIAL</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Una manera de viajar que devuelve la atención a lo verdaderamente importante.</p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
              <path d="M4 8c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 12c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 16c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">NATURALEZA SIN ESCALA</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Paisajes y ecosistemas que transmiten una sensación difícil de encontrar en otro lugar.</p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 12l10 10 10-10L12 2z" />
              <path d="M12 2v20" />
              <path d="M2 12h20" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">LEGADO ANCESTRAL</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Tradiciones, culturas y formas de vida que continúan presentes a través del tiempo.</p>
            </div>
          </div>

          <!-- Pillar 4 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l7-12 5 8" />
              <path d="M8 20l6-9 7 9" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">LIBERTAD Y DESCUBRIMIENTO</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Espacios abiertos que invitan a explorar el mundo desde una perspectiva diferente.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</UniversoLayout>
