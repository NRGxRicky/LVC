---
/**
 * europa.astro — Universo Europa
 */

import UniversoLayout from "../../layouts/UniversoLayout.astro";

const lugares = [
  {
    name: "FRANCIA",
    desc: "Elegancia, sensibilidad y placer por cada detalle.",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "ITALIA",
    desc: "Pasión, belleza y el arte de disfrutar sin prisa.",
    image: "https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "SUIZA",
    desc: "Precisión, calma y lujo en perfecta armonía.",
    image: "https://images.unsplash.com/photo-1530122037265-a5f1f91d3b99?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "GRECIA",
    desc: "Luz, libertad y una belleza que se siente infinita.",
    image: "https://images.unsplash.com/photo-1533105079780-92b9be482077?q=80&w=1000&auto=format&fit=crop"
  },
  {
    name: "ESCOCIA",
    desc: "Profundidad, carácter y una elegancia profundamente reservada.",
    image: "https://images.unsplash.com/photo-1628946578676-e1ee0a952c35?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  },
  {
    name: "NORUEGA",
    desc: "Silencio, inmensidad y conexión con lo esencial.",
    image: "https://images.unsplash.com/photo-1603084612671-be628f06dc06?fm=jpg&q=60&w=3000&auto=format&fit=crop"
  }
];

const experiencias = [
  {
    name: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://garage-web.luxuryvoyageco.com/images/europa_gastro.png"
  },
  {
    name: "ESTANCIAS SELECCIONADAS",
    desc: "Espacios elegidos por lo que hacen sentir.",
    image: "https://garage-web.luxuryvoyageco.com/images/europa_arte.png"
  },
  {
    name: "INMERSIONES",
    desc: "Escenarios que transforman la forma de vivir cada destino.",
    image: "https://garage-web.luxuryvoyageco.com/images/europa_chateau.png"
  }
];
---

<UniversoLayout
  title="Universo Europa — Luxury Voyage Collection"
  description="Donde la historia, el arte y el refinamiento convergen en cada rincón."
  slug="europa"
  heroTitle="EUROPA"
  heroImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/europa.webp"
  heroImageMobile="https://garage-web.luxuryvoyageco.com/images/hero_carousel/europa_mobile.webp"
  heroDesc="Donde cada detalle refleja lo atemporal."
  splitImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/europa.webp"
  lugares={lugares}
  experiencias={experiencias}
>
  <!-- Philosophy Section -->
  <section class="w-full bg-[#EDE7D7] border-t border-[#1C1713]/10 overflow-hidden">
    <div class="max-w-[1920px] mx-auto flex flex-col lg:flex-row items-stretch min-h-[500px]">
      
      <!-- Left Image Column -->
      <div class="w-full lg:w-[35%] xl:w-[38%] min-h-[350px] lg:min-h-0 relative overflow-hidden">
        <img 
          src="/europa_philosophy.png" 
          alt="Lujo atemporal en Europa" 
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Text Content and Pillars Columns -->
      <div class="w-full lg:w-[65%] xl:w-[62%] grid grid-cols-1 md:grid-cols-2">
        
        <!-- Middle Column: Description -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col justify-between min-h-[420px] md:min-h-0">
          <div class="flex flex-col gap-6">
            <div>
              <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">EL ALMA DE EUROPA</span>
              <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
              
              <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] leading-[1.25]">
                Lo que hace de <span class="text-[#D4AD65] italic font-serif">Europa</span><br />
                una experiencia distinta.
              </h2>
            </div>
            
            <div class="flex flex-col gap-4 font-sans text-sm text-[#1C1713]/70 leading-relaxed">
              <p>
                Europa no se define únicamente por sus ciudades, sus monumentos o el legado de su historia.
              </p>
              <p>
                Lo que une a sus destinos es una forma de entender la belleza a través del tiempo, donde tradición, estilo de vida y patrimonio continúan formando parte de la vida cotidiana.
              </p>
              <p>
                Es una región donde cada calle, cada paisaje y cada encuentro reflejan una relación natural entre pasado y presente, creando experiencias que trascienden los lugares que se visitan.
              </p>
            </div>
          </div>
          
          <div class="mt-8">
            <a 
              href="/journey" 
              class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
            >
              NUESTRA FORMA DE ENTENDER EL VIAJE &nbsp;&rarr;
            </a>
          </div>
        </div>

        <!-- Right Column: Pillars -->
        <div class="p-8 md:p-16 lg:py-24 lg:px-20 flex flex-col gap-8 justify-center border-t md:border-t-0 md:border-l border-[#1C1713]/10">
          
          <!-- Pillar 1 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="12" cy="12" r="2.5" />
              <path d="M12 9.5c0-1.5-1-3-2-3s-2 1.5-2 3 1 3 2 3h2v-3z" />
              <path d="M12 9.5c0-1.5 1-3 2-3s2 1.5 2 3-1 3-2 3h-2v-3z" />
              <path d="M12 14.5c0 1.5-1 3-2 3s-2-1.5-2-3 1-3 2-3h2v3z" />
              <path d="M12 14.5c0 1.5 1 3 2 3s2-1.5 2-3-1-3-2-3h-2v3z" />
              <path d="M9.5 12c-1.5 0-3-1-3-2s1.5-2 3-2 3 1 3 2v2H9.5z" />
              <path d="M14.5 12c1.5 0 3-1 3-2s-1.5-2-3-2-3 1-3 2v2h3z" />
              <path d="M9.5 12c-1.5 0-3 1-3 2s1.5 2 3 2 3-1 3-2v-2H9.5z" />
              <path d="M14.5 12c1.5 0 3 1 3 2s-1.5 2-3 2-3-1-3-2v-2h3z" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">EL VALOR DEL LEGADO</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Historias, tradiciones y expresiones culturales que han dado forma a generaciones.</p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
              <path d="M4 8c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 12c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 16c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">BELLEZA QUE PERMANECE</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Arquitectura, arte y paisajes que continúan inspirando con el paso del tiempo.</p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 19c-4-4.5-7.5-6.5-9.5-7 0 0 2-3 6.5-4s8.5.5 10 2c-2.5.5-4.5 2.5-7 9z" />
              <line x1="12" y1="19" x2="6.5" y2="10" />
              <line x1="12" y1="19" x2="10" y2="8.5" />
              <line x1="12" y1="19" x2="14" y2="9.5" />
              <line x1="12" y1="19" x2="17.5" y2="12" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">EL ARTE DE VIVIR</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Una forma de disfrutar cada momento con intención, equilibrio y autenticidad.</p>
            </div>
          </div>

          <!-- Pillar 4 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l7-12 5 8" />
              <path d="M8 20l6-9 7 9" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">TRADICIÓN REINTERPRETADA</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Costumbres que evolucionan sin perder aquello que las hace únicas.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</UniversoLayout>
