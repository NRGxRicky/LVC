---
/**
 * europa.astro — Universo Europa
 */

import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

const lugares = [
  {
    name: "PARÍS",
    desc: "Elegancia, romance y una herencia cultural inigualable.",
    image: "/images/europa_paris.png"
  },
  {
    name: "COSTA AMALFITANA",
    desc: "Acantilados vibrantes y el encanto del Mediterráneo.",
    image: "/images/europa_amalfi.png"
  },
  {
    name: "ALPES SUIZOS",
    desc: "Cumbres nevadas y exclusividad en las alturas.",
    image: "/images/europa_alpes.png"
  }
];

const experiencias = [
  {
    name: "GASTRONOMÍA ESTELAR",
    desc: "Sabores que definen la excelencia culinaria.",
    image: "/images/europa_gastro.png"
  },
  {
    name: "ARTE PRIVADO",
    desc: "Acceso exclusivo a la historia y la cultura.",
    image: "/images/europa_arte.png"
  },
  {
    name: "CHÂTEAUX HISTÓRICOS",
    desc: "Estancias que cuentan historias milenarias.",
    image: "/images/europa_chateau.png"
  }
];
---

<Layout
  title="Universo Europa — Luxury Voyage Collection"
  description="Donde la historia, el arte y el refinamiento convergen en cada rincón."
>
  <Navbar />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HERO EUROPA -->
    <section class="relative w-full h-screen min-h-[700px] flex items-center justify-start overflow-hidden">
      <div class="absolute inset-0 z-0">
        <img 
          src="/images/europa_card_1776310708089.png" 
          alt="Paisaje de Europa" 
          class="w-full h-full object-cover object-[50%_40%]"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#1C1713]/80 via-[#1C1713]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-50% to-[#FAF9F6]"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 md:pl-24 pt-32 pb-24 flex flex-col items-start h-full justify-center">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em]">Universo</span>
          <div class="w-12 h-[1px] bg-[#D4AD65]"></div>
        </div>
        <h1 class="font-heading text-6xl md:text-8xl lg:text-9xl text-white mb-8 tracking-wide">EUROPA</h1>
        <p class="font-sans text-lg text-white/90 max-w-sm mb-12 leading-relaxed">
          Donde la historia, el arte y el refinamiento <span class="text-[#D4AD65] italic">convergen</span> en cada rincón.
        </p>
        <a 
          href="#lugares" 
          class="flex items-center gap-3 font-label text-xs uppercase tracking-widest text-white/80 hover:text-[#D4AD65] transition-colors duration-300 group"
        >
          Explora Europa
          <div class="w-12 h-[1px] bg-white/30 group-hover:bg-[#D4AD65] group-hover:w-16 transition-all duration-300"></div>
        </a>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
            <div class="w-5 h-8 border border-white/30 rounded-full flex justify-center p-1">
                <div class="w-1 h-2 bg-white rounded-full animate-bounce"></div>
            </div>
            <span class="font-label text-[10px] uppercase tracking-widest text-white/50">Scroll</span>
        </div>
      </div>
    </section>

    <!-- LUGARES QUE INSPIRAN -->
    <section id="lugares" class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-16 md:py-24">
        <div class="mb-12 md:mb-16">
            <span class="font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest block mb-4">Escenarios</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-tight">Donde la esencia se vuelve <span class="italic text-[#D4AD65]">lugar</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
            {lugares.map((lugar) => (
                <div class="group relative block w-full aspect-[3/4] overflow-hidden bg-[#1C1713]">
                    <img 
                      src={lugar.image} 
                      alt={lugar.name}
                      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-80 group-hover:opacity-100"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713]/90 via-[#1C1713]/20 to-transparent"></div>
                    
                    <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col">
                      <h3 class="font-heading text-2xl text-white mb-3 tracking-wide">{lugar.name}</h3>
                      <p class="font-sans text-xs text-white/80 leading-relaxed mb-6">
                        {lugar.desc}
                      </p>
                      <div class="flex items-center gap-4 group-hover:gap-6 transition-all duration-300 text-white/50 group-hover:text-[#D4AD65]">
                         <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                      </div>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- FULL WIDTH SPLIT SECTION -->
    <section class="w-full h-[200px] md:h-[300px] relative overflow-hidden flex items-center justify-center">
        <img 
            src="/images/europa_mid.png" 
            alt="Paisaje de Europa"
            class="absolute inset-0 w-full h-full object-cover object-[50%_70%]"
        />
        <div class="absolute inset-0 bg-black/40"></div>
        
        <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 text-center">
            <h2 class="font-heading text-4xl md:text-5xl lg:text-6xl text-white leading-tight">
                Cada lugar es<br>solo el <span class="italic text-[#D4AD65]">inicio</span>.
            </h2>
        </div>
    </section>

    <!-- EXPERIENCIAS QUE TRANSFORMAN -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-16 md:py-24">
        <div class="mb-12 md:mb-16">
            <span class="font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest block mb-4">Momentos diseñados</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-tight">Experiencias<br>que <span class="italic text-[#D4AD65]">transforman</span></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
            {experiencias.map(exp => (
                <div class="group relative block w-full aspect-[9/16] md:aspect-[1/1.8] overflow-hidden bg-[#1C1713]">
                    <img 
                        src={exp.image} 
                        alt={exp.name}
                        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-90 group-hover:opacity-100"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent"></div>
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>
                    
                    <div class="absolute bottom-0 left-0 w-full p-8 md:p-10 flex flex-col items-center text-center">
                        <div class="bg-[#1C1713]/60 backdrop-blur-sm border border-white/10 px-4 py-1.5 mb-6">
                            <span class="font-label text-[9px] text-[#D4AD65] tracking-[0.25em] uppercase">Momentos</span>
                        </div>
                        
                        <h3 class="font-heading text-3xl md:text-4xl text-white mb-4 tracking-wide">{exp.name}</h3>
                        
                        <p class="font-sans text-xs md:text-sm text-white/80 leading-relaxed mb-10 max-w-[85%]">
                            {exp.desc}
                        </p>
                        
                        <a href="/contacto" class="border border-white/30 group-hover:border-[#D4AD65] transition-colors duration-500 px-8 py-3.5 cursor-pointer">
                            <span class="font-label text-[10px] md:text-xs uppercase tracking-widest text-white group-hover:text-[#D4AD65] flex items-center gap-3 transition-colors duration-500">
                                Descubrir
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-1 transition-transform duration-300"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </span>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- BOTTOM CTA -->
    <section class="w-full bg-[#FAF9F6] py-12 md:py-16 text-center">
        <div class="max-w-2xl mx-auto px-6">
            <span class="font-label text-[10px] font-bold text-[#D4AD65] uppercase tracking-[0.2em] block mb-6">Tu viaje, diseñado a tu medida</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] mb-6">Diseña tu experiencia en Europa</h2>
            <p class="font-sans text-[#1C1713]/70 mb-10 text-sm">
                Permítenos crear un viaje que supere todas tus expectativas.
            </p>
            <a 
                href="/contacto" 
                class="inline-flex items-center gap-4 font-label text-xs uppercase tracking-widest font-bold text-white bg-[#1C1713] hover:bg-[#D4AD65] transition-colors duration-300 px-10 py-5"
            >
                Diseña tu experiencia
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
    </section>

  </main>

  <Footer />
</Layout>
