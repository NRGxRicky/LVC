---
/**
 * asia.astro — Universo Asia
 */

import UniversoLayout from "../../layouts/UniversoLayout.astro";

const lugares = [
  {
    name: "JAPÓN",
    desc: "Armonía, precisión y belleza en cada instante.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/japon.webp"
  },
  {
    name: "TAILANDIA",
    desc: "Espiritualidad, calidez y una energía difícil de explicar.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/tailandia.webp"
  },
  {
    name: "INDONESIA",
    desc: "Calma, conexión y una forma distinta de habitar el tiempo.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/indonesia.webp"
  },
  {
    name: "SINGAPUR",
    desc: "Innovación, sofisticación y equilibrio absoluto.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/singapur.webp"
  },
  {
    name: "COREA DEL SUR",
    desc: "Estética, movimiento y una identidad profundamente contemporánea.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/corea_del_sur.jpg"
  },
  {
    name: "MALDIVAS",
    desc: "Privacidad, silencio y desconexión absoluta.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/escenarios/maldivas.webp"
  }
];

const experiencias = [
  {
    name: "EXPERIENCIAS CULINARIAS",
    desc: "La forma en que se vive la alta cocina.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/momentos/culinarias/japon_cena_kaiseki.jpg"
  },
  {
    name: "ESTANCIAS SELECCIONADAS",
    desc: "Espacios elegidos por lo que hacen sentir.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/momentos/estancias/japon_aman_kyoto.webp"
  },
  {
    name: "INMERSIONES",
    desc: "Escenarios que transforman la forma de vivir cada destino.",
    image: "https://garage-web.luxuryvoyageco.com/images/universos/asia/momentos/inmersiones/japon.webp"
  }
];
---

<UniversoLayout
  title="Universo Asia — Luxury Voyage Collection"
  description="Donde la tradición ancestral se encuentra con la belleza en cada detalle."
  slug="asia"
  heroTitle="ASIA"
  heroImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/asia.webp"
  heroImageMobile="https://garage-web.luxuryvoyageco.com/images/hero_carousel/asia_mobile.webp"
  heroDesc="La belleza de la armonía entre contrastes."
  splitImage="https://garage-web.luxuryvoyageco.com/images/hero_carousel/asia.webp"
  lugares={lugares}
  experiencias={experiencias}
>
  <!-- Philosophy Section -->
  <section class="w-full bg-[#EDE7D7] border-t border-[#1C1713]/10 overflow-hidden">
    <div class="max-w-[1920px] mx-auto flex flex-col lg:flex-row items-stretch min-h-[500px] lg:h-[680px] xl:h-[730px]">
      
      <!-- Left Image Column -->
      <div class="w-full lg:w-[35%] min-h-[350px] lg:min-h-0 relative overflow-hidden">
        <img 
          src="https://garage-web.luxuryvoyageco.com/images/asia_philosophy.webp" 
          alt="Meditación al amanecer en Asia" 
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Text Content and Pillars Columns -->
      <div class="w-full lg:w-[65%] grid grid-cols-1 md:grid-cols-2">
        
        <!-- Middle Column: Description -->
        <div class="p-8 md:p-16 lg:py-16 lg:px-12 xl:py-20 xl:px-16 flex flex-col justify-between min-h-[420px] md:min-h-0">
          <div class="flex flex-col gap-6">
            <div>
              <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">EL ALMA DE ASIA</span>
              <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
              
              <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] leading-[1.25]">
                Lo que hace de <span class="text-[#D4AD65] italic font-serif">Asia</span><br />
                una experiencia distinta.
              </h2>
            </div>
            
            <div class="flex flex-col gap-4 font-sans text-sm text-[#1C1713]/70 leading-relaxed">
              <p>
                Asia no se define por un solo país, una sola cultura o una sola forma de viajar.
              </p>
              <p>
                Lo que une a sus destinos es una sensibilidad compartida hacia la belleza, el detalle y la manera en que las personas habitan cada lugar.
              </p>
              <p>
                Es una región donde la tradición permanece presente, la hospitalidad surge con naturalidad y cada experiencia parece encontrar su propio ritmo.
              </p>
            </div>
          </div>
          
          <div class="mt-8">
            <a 
              href="/journey" 
              class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
            >
              NUESTRA FORMA DE ENTENDER EL VIAJE &nbsp;&rarr;
            </a>
          </div>
        </div>

        <!-- Right Column: Pillars -->
        <div class="p-8 md:p-16 lg:py-16 lg:px-12 xl:py-20 xl:px-16 flex flex-col gap-6 xl:gap-8 justify-center border-t md:border-t-0 md:border-l border-[#1C1713]/10">
          
          <!-- Pillar 1 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25">
              <circle cx="12" cy="12" r="2.5" />
              <path d="M12 9.5c0-1.5-1-3-2-3s-2 1.5-2 3 1 3 2 3h2v-3z" />
              <path d="M12 9.5c0-1.5 1-3 2-3s2 1.5 2 3-1 3-2 3h-2v-3z" />
              <path d="M12 14.5c0 1.5-1 3-2 3s-2-1.5-2-3 1-3 2-3h2v3z" />
              <path d="M12 14.5c0 1.5 1 3 2 3s2-1.5 2-3-1-3-2-3h-2v3z" />
              <path d="M9.5 12c-1.5 0-3-1-3-2s1.5-2 3-2 3 1 3 2v2H9.5z" />
              <path d="M14.5 12c1.5 0 3-1 3-2s-1.5-2-3-2-3 1-3 2v2h3z" />
              <path d="M9.5 12c-1.5 0-3 1-3 2s1.5 2 3 2 3-1 3-2v-2H9.5z" />
              <path d="M14.5 12c1.5 0 3 1 3 2s-1.5 2-3 2-3-1-3-2v-2h3z" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">EL VALOR DEL DETALLE</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Pequeños gestos que enriquecen la experiencia sin necesidad de llamar la atención.</p>
            </div>
          </div>

          <!-- Pillar 2 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round">
              <path d="M4 8c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 12c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
              <path d="M4 16c2.5-1.5 4.5-1.5 7 0s4.5 1.5 7 0" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">EL ARTE DE LA CALMA</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Una forma de vivir donde cada momento encuentra su propio ritmo.</p>
            </div>
          </div>

          <!-- Pillar 3 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 19c-4-4.5-7.5-6.5-9.5-7 0 0 2-3 6.5-4s8.5.5 10 2c-2.5.5-4.5 2.5-7 9z" />
              <line x1="12" y1="19" x2="6.5" y2="10" />
              <line x1="12" y1="19" x2="10" y2="8.5" />
              <line x1="12" y1="19" x2="14" y2="9.5" />
              <line x1="12" y1="19" x2="17.5" y2="12" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">TRADICIÓN QUE PERMANECE</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Costumbres y formas de vida que continúan presentes en la vida cotidiana.</p>
            </div>
          </div>

          <!-- Pillar 4 -->
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-[#775A19] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l7-12 5 8" />
              <path d="M8 20l6-9 7 9" />
            </svg>
            <div class="flex flex-col">
              <h3 class="font-label text-xs font-bold text-[#1C1713] uppercase tracking-wider mb-1">BELLEZA CON PROPÓSITO</h3>
              <p class="font-sans text-xs text-[#1C1713]/70 leading-relaxed">Espacios, objetos y experiencias concebidos para generar armonía y significado.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>
</UniversoLayout>
