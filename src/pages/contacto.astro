---
/**
 * contacto.astro — Luxury Voyage Collection
 * Formulario "Diseña tu experiencia"
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Luxury Voyage Collection — Contacto"
  description="Cuéntanos cómo imaginas tu próxima experiencia y nosotros la haremos realidad."
>
  <Navbar theme="dark" />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HEADER CON IMAGEN SUTIL -->
    <div class="relative w-full h-[50vh] min-h-[400px] bg-[#1C1713] flex flex-col justify-center items-center text-center px-6 md:px-12 overflow-hidden">
        <img 
          src="https://garage-web.luxuryvoyageco.com/images/contacto_bottom_1776311078622.png" 
          alt="Experiencias de lujo" 
          class="absolute inset-0 w-full h-full object-cover opacity-30"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-[#1C1713]/60 via-[#1C1713]/40 to-[#FAF9F6]"></div>
        
        <div class="relative z-10 max-w-[800px] mx-auto mt-16">
            <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.2em] block mb-6 reveal-up">DISEÑA TU EXPERIENCIA</span>
            <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl text-white mb-6 reveal-up reveal-delay-100">
              Empieza a dar forma <span class="text-[#D4AD65] italic">a tu viaje</span>
            </h1>
            <p class="font-sans text-white/80 text-sm md:text-base max-w-md mx-auto reveal-up reveal-delay-200 mt-4">Comparte lo esencial. Nosotros nos encargamos del resto.</p>
        </div>
    </div>

    <!-- PREÁMBULO + FORMULARIO -->
    <section class="max-w-[800px] mx-auto px-6 md:px-12 pt-4 md:pt-8 pb-16 md:pb-24">
      


      <!-- FORMULARIO PRINCIPAL -->
      <form id="experience-form" class="flex flex-col gap-10 reveal-up reveal-delay-300">
        
        <!-- DATOS DE CONTACTO PERSONALES -->
        <div class="flex flex-col gap-6 mb-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col gap-2">
              <label for="nombre" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Nombre Completo *</label>
              <input type="text" id="nombre" name="nombre" required class="w-full bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 pt-1 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30" placeholder="Ej. Alejandro Valenzuela" />
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Correo Electrónico *</label>
              <input type="email" id="email" name="email" required class="w-full bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 pt-1 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30" placeholder="correo@ejemplo.com" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="flex flex-col gap-2">
              <label for="telefono" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Teléfono / WhatsApp *</label>
              <input type="tel" id="telefono" name="telefono" required class="w-full bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 pt-1 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30" placeholder="+52 55 1234 5678" />
            </div>
            <div class="flex flex-col gap-2 relative">
              <label for="contacto_pref" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Método de contacto preferido *</label>
              <select id="contacto_pref" name="contacto_pref" required class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 pt-1 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
                <option value="email">Correo Electrónico</option>
                <option value="whatsapp">WhatsApp</option>
                <option value="llamada">Llamada telefónica</option>
                <option value="zoom">Zoom</option>
              </select>
              <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- DESTINO DE INTERÉS -->
        <div class="flex flex-col gap-3">
          <label class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Destino de interés</label>
          <p class="font-sans text-sm text-[#1C1713]/60 -mt-1">¿A dónde te gustaría ir?</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-2">
            <label class="group cursor-pointer">
              <input type="checkbox" name="destino" value="asia" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Asia
              </div>
            </label>
            <label class="group cursor-pointer">
              <input type="checkbox" name="destino" value="africa" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                África
              </div>
            </label>
            <label class="group cursor-pointer">
              <input type="checkbox" name="destino" value="europa" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Europa
              </div>
            </label>
            <label class="group cursor-pointer">
              <input type="checkbox" name="destino" value="medio-oriente" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Medio Oriente
              </div>
            </label>
          </div>
          <label class="flex items-center gap-3 mt-2 cursor-pointer group">
            <input type="checkbox" name="destino" value="indefinido" class="peer sr-only" />
            <div class="w-4 h-4 border border-[#1C1713]/20 flex items-center justify-center transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 peer-checked:opacity-100 transition-opacity"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="font-sans text-xs text-[#1C1713]/50">Aún no lo tengo definido</span>
          </label>
        </div>

        <!-- FECHAS APROXIMADAS -->
        <div class="flex flex-col gap-3">
          <label for="fecha" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Fechas aproximadas</label>
          <p class="font-sans text-sm text-[#1C1713]/60 -mt-1">¿Cuándo te gustaría viajar?</p>
          <div class="relative" id="date-picker-wrapper">
            <input
              type="text"
              id="fecha"
              placeholder="Selecciona tus fechas"
              readonly
              class="w-full bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30 cursor-pointer pr-8"
            />
            <!-- Calendar Icon (clickable) -->
            <button
              type="button"
              id="calendar-toggle"
              class="absolute right-0 bottom-3 opacity-40 hover:opacity-100 text-[#1C1713] hover:text-[#D4AD65] transition-all duration-300"
              aria-label="Abrir calendario"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </button>

            <!-- Calendar Dropdown -->
            <div
              id="calendar-dropdown"
              class="hidden absolute z-50 top-full left-1/2 -translate-x-1/2 md:left-0 md:translate-x-0 mt-3 w-full max-w-[320px] bg-[#FAF9F6] border border-[#1C1713]/10 shadow-2xl select-none"
            >
              <!-- Header -->
              <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-[#1C1713]/8">
                <button type="button" id="cal-prev" class="w-8 h-8 flex items-center justify-center text-[#1C1713]/40 hover:text-[#D4AD65] hover:bg-[#D4AD65]/10 transition-all duration-200">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <span id="cal-month-label" class="font-heading text-sm text-[#1C1713] tracking-wide uppercase"></span>
                <button type="button" id="cal-next" class="w-8 h-8 flex items-center justify-center text-[#1C1713]/40 hover:text-[#D4AD65] hover:bg-[#D4AD65]/10 transition-all duration-200">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
              </div>

              <!-- Day Labels -->
              <div class="grid grid-cols-7 px-4 pt-3 pb-1">
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Lu</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Ma</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Mi</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Ju</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Vi</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Sá</span>
                <span class="text-center font-label text-[9px] uppercase tracking-widest text-[#1C1713]/30">Do</span>
              </div>

              <!-- Days Grid -->
              <div id="cal-days" class="grid grid-cols-7 px-4 pb-4 gap-y-1"></div>

              <!-- Footer hint -->
              <div class="px-5 pb-4 pt-1 border-t border-[#1C1713]/8">
                <p id="cal-hint" class="font-sans text-[10px] text-[#1C1713]/40 text-center">Selecciona fecha de inicio</p>
              </div>
            </div>
          </div>

          <label class="flex items-center gap-3 mt-1 cursor-pointer group">
            <input type="checkbox" name="fechas_flexible" value="true" class="peer sr-only" />
            <div class="w-4 h-4 border border-[#1C1713]/20 flex items-center justify-center transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]">
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="opacity-0 peer-checked:opacity-100 transition-opacity"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <span class="font-sans text-xs text-[#1C1713]/50">Soy flexible con las fechas</span>
          </label>
        </div>

        <!-- NIVEL DE INVERSIÓN -->
        <div class="flex flex-col gap-2 relative group">
            <label for="inversion" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Nivel de inversión aproximado</label>
            <p class="font-sans text-sm text-[#1C1713]/60">Selecciona el rango que mejor se ajuste</p>
            <select id="inversion" class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 pt-1 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
              <option value="" disabled selected>Selecciona un rango</option>
              <option value="tier1">$10,000 - $25,000 USD</option>
              <option value="tier2">$25,000 - $50,000 USD</option>
              <option value="tier3">Más de $50,000 USD</option>
              <option value="nolimit">Presupuesto abierto</option>
            </select>
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
        </div>

        <!-- TIPO DE EXPERIENCIA -->
        <div class="flex flex-col gap-3">
          <label class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Tipo de experiencia</label>
          <p class="font-sans text-sm text-[#1C1713]/60 -mt-1">¿Qué tipo de experiencias te interesan?</p>
          <div class="grid grid-cols-2 gap-3 mt-2">
            <label class="cursor-pointer">
              <input type="checkbox" name="experiencia" value="culinarias" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Experiencias culinarias
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" name="experiencia" value="estancias" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Estancias seleccionadas
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" name="experiencia" value="momentos" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Momentos del viaje
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="checkbox" name="experiencia" value="todo" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-4 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Me interesa todo
              </div>
            </label>
          </div>
        </div>

        <!-- NÚMERO DE VIAJEROS -->
        <div class="flex flex-col gap-3">
          <label class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Número de viajeros</label>
          <p class="font-sans text-sm text-[#1C1713]/60 -mt-1">¿Con quién viajas?</p>
          <div class="grid grid-cols-4 gap-3 mt-2">
            <label class="cursor-pointer">
              <input type="radio" name="viajeros" value="solo" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-3 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Solo
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="viajeros" value="pareja" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-3 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Pareja
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="viajeros" value="familia" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-3 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Familia
              </div>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="viajeros" value="grupo" class="peer sr-only" />
              <div class="border border-[#1C1713]/15 px-3 py-3 text-center font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]/60 transition-all duration-300 peer-checked:border-[#D4AD65] peer-checked:bg-[#D4AD65]/10 peer-checked:text-[#775A19] hover:border-[#D4AD65]/50">
                Grupo
              </div>
            </label>
          </div>
        </div>

        <!-- TEXTAREA -->
        <div class="flex flex-col gap-3">
            <label for="idea" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">¿Cómo te gustaría vivir este viaje?</label>
            <textarea id="idea" name="idea" rows="4" placeholder="Cuéntanos lo que tienes en mente, aunque aún no esté completamente definido." class="w-full bg-transparent border border-[#1C1713]/10 p-6 font-sans text-sm text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30 resize-none hover:border-[#1C1713]/20"></textarea>
        </div>

        <!-- SEGURIDAD & SUBMIT -->
        <div class="flex flex-col items-center gap-6">
            <div class="flex items-center gap-2 text-[#1C1713]/40 text-[10px] md:text-xs font-sans text-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Tu información será tratada con absoluta confidencialidad.</span>
            </div>

            <button type="submit" class="group/submit relative overflow-hidden bg-[#1C1713] text-[#D4AD65] font-label text-xs uppercase tracking-[0.2em] font-bold px-14 py-5 transition-all duration-500 rounded-none w-full md:w-auto shadow-xl">
              <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/submit:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
              <span class="relative z-10 flex items-center justify-center gap-3 group-hover/submit:text-[#1C1713] transition-colors duration-500">
                Diseñar mi experiencia
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/submit:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </span>
            </button>
        </div>
      </form>

      <!-- SUCCESS MODAL -->
      <div
        id="success-modal"
        class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#1C1713]/80 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500"
        role="dialog"
        aria-modal="true"
        aria-labelledby="modal-title"
      >
        <div class="bg-[#FAF9F6] border border-[#D4AD65]/30 p-8 md:p-12 max-w-lg w-full text-center relative shadow-2xl rounded-[2px] transform scale-95 transition-transform duration-500" id="modal-card">
          <div class="text-[#D4AD65] text-2xl mb-6">✦</div>
          <h2 id="modal-title" class="font-heading text-2xl md:text-3xl text-[#1C1713] uppercase tracking-wider mb-4">Diseño en Proceso</h2>
          <div class="w-12 h-[1px] bg-[#D4AD65] mx-auto mb-6"></div>
          <p id="modal-message" class="font-sans text-sm md:text-base text-[#1C1713]/80 leading-relaxed mb-8">
            Tu solicitud ha sido recibida con éxito. Un Diseñador de Viajes de Luxury Voyage Collection analizará tus preferencias y se pondrá en contacto contigo en un plazo máximo de 24 horas para dar inicio al diseño de tu experiencia a la medida.
          </p>
          <button
            type="button"
            id="close-modal"
            class="inline-flex font-label text-[10px] uppercase tracking-widest font-bold text-[#1C1713] bg-[#E6C875] hover:bg-[#D4AD65] transition-all duration-300 px-8 py-3.5"
          >
            Entendido
          </button>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  (() => {
    console.log("✦ LVC: Script de contacto cargado!");
    // Select elements safely
    const toggle   = document.getElementById('calendar-toggle');
    const input    = document.getElementById('fecha') as HTMLInputElement | null;
    const dropdown = document.getElementById('calendar-dropdown');
    const prevBtn  = document.getElementById('cal-prev');
    const nextBtn  = document.getElementById('cal-next');
    const label    = document.getElementById('cal-month-label');
    const daysGrid = document.getElementById('cal-days');
    const hint     = document.getElementById('cal-hint');

    const form = document.getElementById('experience-form') as HTMLFormElement | null;
    const successModal = document.getElementById('success-modal');
    
    // Debug click en botón
    const submitBtnDebug = form?.querySelector('button[type="submit"]');
    if (submitBtnDebug) {
      console.log("✦ LVC: Botón submit encontrado en el DOM!");
      submitBtnDebug.addEventListener('click', (e) => {
        console.log("✦ LVC: Click directo detectado en el botón!");
      });
    }
    const modalCard = document.getElementById('modal-card');
    const closeModal = document.getElementById('close-modal');
    const modalMessage = document.getElementById('modal-message');

    const MONTHS = ['Enero','Febrero','Marzo','Abril','Mayo','Junio',
                    'Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

    let today    = new Date();
    let current  = new Date(today.getFullYear(), today.getMonth(), 1);
    let startDate: Date | null = null;
    let endDate: Date | null = null;

    function isSameDay(a: Date | null, b: Date | null) {
      return a && b &&
        a.getFullYear() === b.getFullYear() &&
        a.getMonth()    === b.getMonth() &&
        a.getDate()     === b.getDate();
    }

    function formatDate(d: Date) {
      return d.toLocaleDateString('es-MX', { day:'2-digit', month:'short', year:'numeric' });
    }

    function render() {
      if (!label || !daysGrid) return;
      label.textContent = MONTHS[current.getMonth()] + ' ' + current.getFullYear();
      daysGrid.innerHTML = '';

      const year  = current.getFullYear();
      const month = current.getMonth();
      const firstDay = new Date(year, month, 1);
      // Monday-first offset
      let startOffset = firstDay.getDay() - 1;
      if (startOffset < 0) startOffset = 6;

      const daysInMonth = new Date(year, month + 1, 0).getDate();

      // Empty cells
      for (let i = 0; i < startOffset; i++) {
        const empty = document.createElement('div');
        daysGrid.appendChild(empty);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const date = new Date(year, month, d);
        const btn  = document.createElement('button');
        btn.type = 'button';
        btn.textContent = String(d);

        const isPast   = date < new Date(today.getFullYear(), today.getMonth(), today.getDate());
        const isStart  = isSameDay(date, startDate);
        const isEnd    = isSameDay(date, endDate);
        const isInRange = startDate && endDate && date > startDate && date < endDate;

        btn.className = [
          'w-full aspect-square flex items-center justify-center text-xs font-sans transition-all duration-150',
          isPast   ? 'opacity-20 cursor-not-allowed' : 'hover:bg-[#D4AD65]/15 hover:text-[#775A19] cursor-pointer',
          isStart  ? 'bg-[#1C1713] text-[#D4AD65] font-bold' : '',
          isEnd    ? 'bg-[#1C1713] text-[#D4AD65] font-bold' : '',
          isInRange ? 'bg-[#D4AD65]/15 text-[#775A19]' : '',
          (!isStart && !isEnd && !isInRange && !isPast) ? 'text-[#1C1713]' : ''
        ].join(' ');

        if (!isPast) {
          btn.addEventListener('click', () => selectDate(date));
        }

        daysGrid.appendChild(btn);
      }
    }

    function selectDate(date: Date) {
      if (!hint || !input || !dropdown) return;
      if (!startDate || (startDate && endDate)) {
        // Start fresh
        startDate = date;
        endDate   = null;
        hint.textContent = 'Selecciona fecha de regreso';
        input.value = formatDate(startDate) + '  →  ...';
      } else {
        if (date < startDate) {
          endDate   = startDate;
          startDate = date;
        } else if (isSameDay(date, startDate)) {
          // Same day = single date
          endDate = date;
        } else {
          endDate = date;
        }
        hint.textContent = 'Fechas seleccionadas ✓';

        // Update input
        if (isSameDay(startDate, endDate)) {
          input.value = formatDate(startDate);
        } else {
          input.value = formatDate(startDate) + '  →  ' + formatDate(endDate);
        }

        // Close after short delay
        setTimeout(() => closeCalendar(), 500);
      }
      render();
    }

    // Open / Close / Toggle / Cleanup
    function openCalendar() {
      if (!dropdown) return;
      dropdown.classList.remove('hidden');
      render();
    }

    function closeCalendar() {
      if (!dropdown) return;
      dropdown.classList.add('hidden');
      if (startDate && !endDate && input) {
        input.value = formatDate(startDate);
      }
    }

    if (toggle) {
      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        if (dropdown) {
          const isCurrentlyHidden = dropdown.classList.contains('hidden');
          if (isCurrentlyHidden) {
            openCalendar();
          } else {
            closeCalendar();
          }
        }
      });
    }

    if (input) {
      input.addEventListener('click', () => openCalendar());
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        current = new Date(current.getFullYear(), current.getMonth() - 1, 1);
        render();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        current = new Date(current.getFullYear(), current.getMonth() + 1, 1);
        render();
      });
    }

    // Close on outside click
    document.addEventListener('click', (e) => {
      const pickerWrapper = document.getElementById('date-picker-wrapper');
      if (pickerWrapper && !pickerWrapper.contains(e.target as Node) && dropdown) {
        closeCalendar();
      }
    });

    // Form submission & validation
    if (form) {
      console.log("✦ LVC: Listener de submit registrado en el formulario!");
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        console.log("✦ LVC: Submit del formulario disparado!");

        const nombreInput = document.getElementById('nombre') as HTMLInputElement | null;
        const emailInput = document.getElementById('email') as HTMLInputElement | null;
        const telefonoInput = document.getElementById('telefono') as HTMLInputElement | null;
        const prefInput = document.getElementById('contacto_pref') as HTMLSelectElement | null;

        if (!nombreInput || !emailInput || !telefonoInput || !prefInput) return;

        // Basic XSS escaping for safety
        const sanitize = (val: string) => val.replace(/</g, "&lt;").replace(/>/g, "&gt;");
        const nombre = sanitize(nombreInput.value.trim());
        const pref = prefInput.value;

        // Obtener preferencias del viaje para compilarlas en el mensaje
        const destinos = Array.from(document.querySelectorAll('input[name="destino"]:checked')).map(el => (el as HTMLInputElement).value).join(', ') || 'Ninguno seleccionado';
        const fecha = (document.getElementById('fecha') as HTMLInputElement | null)?.value || 'No especificada';
        const flexible = (document.querySelector('input[name="fechas_flexible"]') as HTMLInputElement)?.checked ? 'Sí' : 'No';
        const inversionSelect = document.getElementById('inversion') as HTMLSelectElement | null;
        const inversion = inversionSelect ? inversionSelect.options[inversionSelect.selectedIndex]?.text : 'No seleccionada';
        const experiencias = Array.from(document.querySelectorAll('input[name="experiencia"]:checked')).map(el => (el as HTMLInputElement).value).join(', ') || 'Ninguna seleccionada';
        const viajeros = (document.querySelector('input[name="viajeros"]:checked') as HTMLInputElement)?.value || 'No especificado';
        const idea = (document.getElementById('idea') as HTMLTextAreaElement | null)?.value?.trim() || 'Sin mensaje adicional';

        const compiledMessage = `--- DETALLES DEL VIAJE ---
• Método de contacto preferido: ${pref}
• Destinos de interés: ${destinos}
• Fechas de viaje: ${fecha} (Flexible: ${flexible})
• Nivel de inversión: ${inversion}
• Viajeros: ${viajeros}
• Experiencias deseadas: ${experiencias}

--- MENSAJE ADICIONAL ---
${idea}`;

        // Separar nombre y apellidos para mapear a los campos de HubSpot
        const nameParts = nombre.split(" ");
        const firstname = nameParts[0] || "";
        const lastname = nameParts.slice(1).join(" ") || "";

        // Enviar a HubSpot Form API v3 (Submission API)
        const portalId = import.meta.env.PUBLIC_HUBSPOT_PORTAL_ID || "51495057";
        const formId = import.meta.env.PUBLIC_HUBSPOT_FORM_ID || "b25257b0-7b1a-43b8-a591-fa2853b7a244";
        const endpoint = `https://api.hsforms.com/submissions/v3/integration/submit/${portalId}/${formId}`;

        const payload = {
          fields: [
            { name: "firstname", value: firstname },
            { name: "lastname", value: lastname },
            { name: "email", value: emailInput.value.trim() },
            { name: "phone", value: telefonoInput.value.trim() },
            { name: "message", value: compiledMessage }
          ],
          context: {
            pageUri: window.location.href,
            pageName: document.title
          }
        };

        // Mostrar un estado visual de carga en el botón (opcional, pero mejora UX)
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalBtnContent = submitBtn ? submitBtn.innerHTML : '';
        if (submitBtn) {
          submitBtn.setAttribute('disabled', 'true');
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        }

        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
          });

          if (!response.ok) {
            console.error("HubSpot submission failed:", await response.text());
          }
        } catch (error) {
          console.error("Error submitting to HubSpot:", error);
        } finally {
          // Restaurar botón
          if (submitBtn) {
            submitBtn.removeAttribute('disabled');
            submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
          }
        }

        let canalText = "correo electrónico";
        if (pref === "whatsapp") canalText = "WhatsApp";
        else if (pref === "llamada") canalText = "llamada telefónica";
        else if (pref === "zoom") canalText = "Zoom";

        if (modalMessage) {
          modalMessage.innerHTML = `Estimado(a) <strong>${nombre}</strong>, su solicitud ha sido recibida con éxito. Un Diseñador de Viajes de Luxury Voyage Collection analizará sus preferencias y se pondrá en contacto con usted mediante <strong>${canalText}</strong> en un plazo máximo de 24 horas.`;
        }

        // Show Success Modal
        if (successModal && modalCard) {
          successModal.classList.remove('opacity-0', 'pointer-events-none');
          successModal.classList.add('opacity-100');
          modalCard.classList.remove('scale-95');
          modalCard.classList.add('scale-100');
          document.body.style.overflow = "hidden";
        }
      });
    }

    if (closeModal && successModal && modalCard && form) {
      closeModal.addEventListener('click', () => {
        // Close Success Modal
        successModal.classList.remove('opacity-100');
        successModal.classList.add('opacity-0', 'pointer-events-none');
        modalCard.classList.remove('scale-100');
        modalCard.classList.add('scale-95');
        document.body.style.overflow = "";

        // Reset Form
        form.reset();
        startDate = null;
        endDate = null;
        if (input) input.value = "";
      });
    }
  })();
</script>

<style>
  /* Make peer-checked checkmark visible */
  input:checked ~ div svg {
    opacity: 1;
  }
  #calendar-dropdown {
    box-shadow: 0 20px 60px rgba(28,23,19,0.12), 0 4px 16px rgba(28,23,19,0.08);
  }
</style>
