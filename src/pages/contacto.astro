---
/**
 * contacto.astro — Luxury Voyage Collection
 * Formulario "Diseña tu experiencia"
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Luxury Voyage Collection — Contacto"
  description="Cuéntanos cómo imaginas tu próxima experiencia y nosotros la haremos realidad."
>
  <Navbar theme="dark" />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HEADER OSCURO CON PARALLAX NATIVO -->
    <div class="relative w-full h-[60vh] min-h-[500px] bg-[#1C1713] bg-[url('/images/safari_split_media.jpg')] bg-fixed bg-cover bg-center flex flex-col justify-center items-center text-center px-6 md:px-12">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-[2px]"></div> <!-- Oscurecimiento profundo -->
        
        <div class="relative z-10 max-w-[1000px] mx-auto mt-16">
            <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.2em] block mb-6 reveal-up">Privacidad y Exclusividad</span>
            <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl text-white mb-6 reveal-up reveal-delay-100">
              Diseña tu <span class="italic text-[#D4AD65]">próximo viaje</span>
            </h1>
            <p class="font-sans text-sm text-white/70 max-w-xl mx-auto leading-relaxed reveal-up reveal-delay-200">
              Nuestros especialistas están listos para orquestar cada detalle de tu expedición.
            </p>
        </div>
    </div>

    <!-- FORMULARIO ELEGANTE (MODO CLARO - TIER 1) -->
    <section class="max-w-[800px] mx-auto px-6 md:px-12 py-24 reveal-up reveal-delay-300">
      <form class="flex flex-col gap-10">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
          <!-- DESTINO -->
          <div class="flex flex-col gap-2 relative group">
            <label for="destino" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Destino de interés</label>
            <select id="destino" class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
              <option value="" disabled selected>Selecciona un destino</option>
              <option value="asia">Asia</option>
              <option value="africa">África</option>
              <option value="europa">Europa</option>
              <option value="oriente">Medio Oriente</option>
              <option value="multiple">Múltiples Destinos</option>
            </select>
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>

          <!-- TIPO DE EXPERIENCIA -->
          <div class="flex flex-col gap-2 relative group">
            <label for="tipo" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Tipo de experiencia</label>
            <select id="tipo" class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
              <option value="" disabled selected>Selecciona una opción</option>
              <option value="desconexion">Desconexión y Spa</option>
              <option value="aventura">Aventura Activa</option>
              <option value="gastronomia">Gastronomía y Cultura</option>
              <option value="romance">Romance / Luna de Miel</option>
            </select>
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
          <!-- FECHAS -->
          <div class="flex flex-col gap-2 relative group">
            <label for="fecha" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Fechas aproximadas</label>
            <input type="text" id="fecha" placeholder="¿Cuándo quieres viajar?" class="w-full bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30 cursor-text" />
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-30 text-[#1C1713]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
          </div>

          <!-- VIAJEROS -->
          <div class="flex flex-col gap-2 relative group">
            <label for="viajeros" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Número de viajeros</label>
            <select id="viajeros" class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
              <option value="" disabled selected>Selecciona cantidad</option>
              <option value="1">1 Persona</option>
              <option value="2">2 Personas</option>
              <option value="3-4">3 a 4 Personas</option>
              <option value="5+">5 o más</option>
            </select>
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <!-- NIVEL DE INVERSIÓN -->
        <div class="flex flex-col gap-2 relative group">
            <label for="inversion" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50">Nivel de inversión aproximado</label>
            <select id="inversion" class="w-full appearance-none bg-transparent border-0 border-b border-[#1C1713]/20 pb-3 font-sans text-base text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none cursor-pointer">
              <option value="" disabled selected>Selecciona el rango que mejor se ajuste</option>
              <option value="tier1">$10,000 - $25,000 USD</option>
              <option value="tier2">$25,000 - $50,000 USD</option>
              <option value="tier3">Más de $50,000 USD</option>
              <option value="nolimit">Presupuesto abierto</option>
            </select>
            <div class="absolute right-0 bottom-4 pointer-events-none opacity-40 text-[#1C1713]">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </div>
        </div>

        <!-- TEXTAREA -->
        <div class="flex flex-col gap-2 mt-4">
            <label for="idea" class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-[#1C1713]/50 mb-4">Cuéntanos tu idea</label>
            <textarea id="idea" rows="4" placeholder="Comparte detalles sobre tu viaje ideal, intereses, ocasiones especiales..." class="w-full bg-transparent border border-[#1C1713]/10 p-6 font-sans text-sm text-[#1C1713] focus:ring-0 focus:outline-none focus:border-[#D4AD65] transition-colors rounded-none placeholder:text-[#1C1713]/30 resize-none hover:border-[#1C1713]/20"></textarea>
        </div>

        <!-- SEGURIDAD & SUBMIT -->
        <div class="flex flex-col items-center mt-10 gap-8">
            <div class="flex items-center gap-2 text-[#1C1713]/40 text-[10px] md:text-xs font-sans text-center">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>Tu información está protegida y será tratada con absoluta confidencialidad por nuestro equipo.</span>
            </div>

            <button type="button" class="bg-[#1C1713] text-[#D4AD65] font-label text-xs uppercase tracking-[0.2em] font-bold px-14 py-5 hover:bg-[#D4AD65] hover:text-white transition-colors duration-500 rounded-none w-full md:w-auto shadow-xl">
              Enviar Solicitud
            </button>
        </div>
      </form>
    </section>

    <!-- BRAND FOOTER SECTION CON PARALLAX ADICIONAL -->
    <section class="max-w-[1920px] mx-auto flex flex-col md:flex-row min-h-[500px]">
        <div class="w-full md:w-1/2 relative bg-[#1C1713] overflow-hidden min-h-[300px] bg-[url('/images/contacto_bottom_1776311078622.png')] bg-fixed bg-cover bg-center">
           <div class="absolute inset-0 bg-black/40 mix-blend-multiply"></div>
        </div>
        <div class="w-full md:w-1/2 bg-[#EFECE8] p-12 md:p-24 flex flex-col justify-center">
            <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.2em] block mb-4">Experiencias únicas</span>
            <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] mb-8 leading-[1.2]">
              Permítenos crear recuerdos que perdurarán para siempre.
            </h2>
            <p class="font-sans text-[#1C1713]/70 mb-10 max-w-sm">
                En Luxury Voyage Collection nos encargamos de cada detalle para que solo tengas que preocuparte por disfrutar.
            </p>
            <a href="/journey" class="flex items-center gap-3 text-xs font-label uppercase tracking-[0.2em] text-[#775A19] group w-max">
                <span class="hover:text-[#1C1713] transition-colors">Conoce nuestra historia</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-2 transition-transform duration-300"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
        </div>
    </section>

  </main>

  <Footer />
</Layout>
