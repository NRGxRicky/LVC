    image: "https://garage-web.luxuryvoyageco.com/images/universos/europa/escenarios/francia.webp",
    link: "/colecciones/capitales-del-norte"
  }
];

const africaCollections = [
  {
    title: "Safari de Lujo",
    subtitle: "KENIA & TANZANIA",
    description: "Encuentros íntimos con la fauna salvaje en campamentos móviles de lujo en el Serengueti.",
    image: "https://garage-web.luxuryvoyageco.com/images/hero_carousel/africa.webp",
    link: "/colecciones/safari-lujo"
  },
  {
    title: "Sudáfrica Exclusiva",
    subtitle: "SUDÁFRICA",
    description: "La ruta de los viñedos en Stellenbosch, el Cabo de Buena Esperanza y avistamiento de ballenas.",
    image: "https://garage-web.luxuryvoyageco.com/images/colecciones/card_south_africa.webp",
    link: "/colecciones/sudafrica-exclusiva"
  },
  {
    title: "Marruecos Imperial",
    subtitle: "MARRUECOS",
    description: "Ríads de ensueño en Marrakech y noches estrelladas en campamentos bereberes del Sahara.",
    image: "https://garage-web.luxuryvoyageco.com/images/colecciones/card_morocco.webp",
    link: "/colecciones/marruecos-imperial"
  },
  {
    title: "Egipto Eterno",
    subtitle: "EGIPTO",
    description: "Cruceros privados de lujo por el Nilo y visitas exclusivas fuera de horario a las pirámides de Giza.",
    image: "https://images.unsplash.com/photo-1503177119275-0aa32b3a9368?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/egipto-eterno"
  },
  {
    title: "Botsuana Salvaje",
    subtitle: "BOTSUANA",
    description: "Exploración en mokoro por el Delta del Okavango, el santuario de vida silvestre más exclusivo.",
    image: "https://images.unsplash.com/photo-1577971132997-c10be9372519?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/botsuana-salvaje"
  },
  {
    title: "Gorilas en Ruanda",
    subtitle: "RUANDA",
    description: "Senderismo en la selva nubosa para un encuentro íntimo de una hora con los últimos gorilas de montaña.",
