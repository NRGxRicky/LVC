---
/**
 * colecciones.astro — Itinerarios Pre-armados
 * Luxury Voyage Collection
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Colecciones — Luxury Voyage Collection"
  description="Itinerarios cuidadosamente diseñados para vivir experiencias extraordinarias en los destinos más exclusivos del mundo."
>
  <Navbar theme="dark" />

  <main class="w-full bg-[#FAF9F6]">
    
    <!-- HERO -->
    <section class="relative w-full h-[70vh] min-h-[500px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 z-0 bg-[#1C1713]">
        <img 
          src="/images/home_hero_architecture.png" 
          alt="Colecciones de viaje" 
          class="w-full h-full object-cover opacity-50"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-[#1C1713]/40 via-transparent via-50% to-[#FAF9F6]"></div>
      </div>
      
      <div class="relative z-10 text-center px-6 max-w-3xl">
        <span class="font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em] block mb-6 reveal-up">Itinerarios curados</span>
        <h1 class="font-heading text-5xl md:text-7xl text-white mb-6 reveal-up reveal-delay-100">
          Nuestras <span class="italic text-[#D4AD65]">Colecciones</span>
        </h1>
        <p class="font-sans text-sm md:text-base text-white/70 max-w-xl mx-auto leading-relaxed reveal-up reveal-delay-200">
          Viajes cuidadosamente diseñados para quienes buscan lo extraordinario sin comprometer ningún detalle.
        </p>
      </div>
    </section>

    <!-- COMING SOON -->
    <section class="w-full max-w-[1920px] mx-auto px-6 md:px-12 py-12 md:py-16 text-center">
      <div class="max-w-xl mx-auto">
        <div class="w-12 h-[2px] bg-[#D4AD65] mx-auto mb-8"></div>
        <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] mb-6">Próximamente</h2>
        <p class="font-sans text-sm text-[#1C1713]/70 leading-relaxed mb-10">
          Estamos preparando una selección de itinerarios exclusivos para cada universo. Mientras tanto, te invitamos a contactarnos para diseñar una experiencia completamente personalizada.
        </p>
        <a 
          href="/contacto" 
          class="group/cta relative overflow-hidden inline-flex items-center gap-4 font-label text-[10px] md:text-xs uppercase tracking-widest font-bold text-[#FAF9F6] bg-[#1C1713] px-8 py-4 transition-all duration-500"
        >
          <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
          <span class="relative z-10 flex items-center gap-4 transition-colors duration-500">
            Diseña tu experiencia
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
