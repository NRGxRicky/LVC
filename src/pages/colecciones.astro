    link: "/colecciones/oasis-golfo"
  },
  {
    title: "Omán Tradicional",
    subtitle: "OMÁN",
    description: "Cañones espectaculares, fuertes antiguos y la hospitalidad más pura de la Península Arábiga.",
    image: "https://images.unsplash.com/photo-1578894381163-e72c17f2d45f?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/oman-tradicional"
  },
  {
    title: "Doha & Sofisticación",
    subtitle: "CATAR",
    description: "Diseño contemporáneo en museos flotantes de primer nivel, zocos tradicionales y resorts a orillas del Golfo.",
    image: "https://images.unsplash.com/photo-1669815007479-494b3b51c2c3?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/doha-sofisticacion"
  },
  {
    title: "AlUla Arqueológica",
    subtitle: "ARABIA SAUDITA",
    description: "Exploración en helicóptero sobre las antiguas tumbas de Hegra y estancia en el vanguardista hotel de espejos Maraya.",
    image: "https://images.unsplash.com/photo-1663900108404-a05e8bf82cda?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/alula-arqueologica"
  },
  {
    title: "Joyas de Abu Dabi",
    subtitle: "EMIRATOS ÁRABES UNIDOS",
    description: "Visita al majestuoso museo Louvre Abu Dabi y la icónica Mezquita Sheikh Zayed en un itinerario artístico privado.",
    image: "https://images.unsplash.com/photo-1545459720-aac8509eb02c?q=80&w=600&auto=format&fit=crop",
    link: "/colecciones/joyas-abu-dabi"
  }
];
---

<Layout
  title="Colecciones — Luxury Voyage Collection"
  description="Viajes cuidadosamente diseñados para descubrir el mundo en su máxima expresión de lujo."
>
  <Navbar theme="light" />

  <main class="w-full bg-[#EDE7D7] overflow-hidden">
    
    <!-- SECCIÓN 1: INTRODUCCIÓN EDITORIAL -->
    <section class="relative w-full pt-32 pb-16 md:pt-44 md:pb-24 px-6 md:px-12 lg:px-20 max-w-[1920px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <!-- Columna Izquierda: Texto -->
        <div class="lg:col-span-5 flex flex-col justify-center reveal-up">
          <h1 class="font-heading text-4xl md:text-5xl lg:text-[3.5rem] text-[#1C1713] leading-[1.15] mb-8 select-none">
            Colecciones<br />
            diseñadas para<br />
            <span class="text-[#775A19] italic font-serif">descubrir</span> el mundo.
          </h1>
          <div class="w-12 h-[1px] bg-[#775A19] mb-8"></div>
          <p class="font-sans text-sm md:text-base text-[#645D5A] leading-relaxed max-w-md">
            Elegidas con el mismo cuidado que distingue cada experiencia de Luxury Voyage Collection, para quienes encuentran valor en la forma de vivir cada destino.
          </p>
        </div>

        <!-- Columna Derecha: Composición asimétrica de imágenes con efecto Parallax -->
        <div class="lg:col-span-7 relative flex items-center justify-center min-h-[380px] sm:min-h-[500px] md:min-h-[580px] reveal-up reveal-delay-200">
          <!-- Imagen Principal Arqueada (Taj Mahal Gateway) -->
          <div 
            id="parallax-gateway" 
            class="absolute w-[60%] h-[90%] left-0 top-0 overflow-hidden rounded-lg shadow-2xl z-10"
            style="will-change: transform; transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);"
          >
            <img 
              src="https://garage-web.luxuryvoyageco.com/images/colecciones/intro_arched_gateway.webp" 
              alt="Puerta de arco histórico al Taj Mahal" 
              class="w-full h-full object-cover select-none"
              draggable="false"
            />
          </div>
          <!-- Imagen Secundaria Desplazada (Misty Hills) -->
          <div 
            id="parallax-hills" 
            class="absolute w-[52%] h-[62%] right-0 bottom-2 overflow-hidden rounded-lg shadow-xl z-20"
            style="will-change: transform; transition: transform 0.2s cubic-bezier(0.25, 1, 0.5, 1);"
          >
            <img 
              src="https://garage-web.luxuryvoyageco.com/images/colecciones/intro_misty_hills.webp" 
              alt="Colinas con niebla al amanecer" 
              class="w-full h-full object-cover select-none"
              draggable="false"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- SECCIÓN 2: EXPLORA POR CONTINENTE -->
    <section class="w-full bg-[#F0EEE9] py-20 md:py-28 px-6 md:px-12 lg:px-20 border-t border-[#1C1713]/10">
      <div class="max-w-[1920px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Columna Izquierda: Introducción del Continente -->
        <div class="lg:col-span-4 flex flex-col justify-center reveal-up">
          <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-[0.25em] mb-4">EL MUNDO, EN SU ESENCIA</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-[2.75rem] text-[#1C1713] leading-tight mb-6">
            Cada elección<br />
            <span class="text-[#775A19] italic font-serif">dice algo.</span>
          </h2>
          <div class="w-12 h-[1px] bg-[#775A19] mb-8"></div>
          <p class="font-sans text-sm md:text-base text-[#645D5A] leading-relaxed max-w-sm">
            Detrás de cada una existe una forma distinta de sorprenderse, conectar y crear recuerdos que permanecen mucho después del viaje.
          </p>
        </div>

        <!-- Columna Derecha: Pestañas e Itinerarios -->
        <div class="lg:col-span-8 flex flex-col reveal-up reveal-delay-200">
          <!-- Menú de Pestañas -->
          <div class="flex border-b border-[#1C1713]/15 mb-10 overflow-x-auto scrollbar-none gap-8 md:gap-12 pb-4">
            <button 
              class="continent-tab-btn active text-xs font-label uppercase tracking-widest font-bold pb-2 border-b-2 border-[#775A19] text-[#775A19] transition-all duration-300 whitespace-nowrap cursor-pointer" 
              data-continent="asia"
            >
              Asia
            </button>
            <button 
              class="continent-tab-btn text-xs font-label uppercase tracking-widest font-bold pb-2 border-b-2 border-transparent text-[#645D5A] hover:text-[#1C1713] transition-all duration-300 whitespace-nowrap cursor-pointer" 
              data-continent="europa"
            >
              Europa
            </button>
            <button 
              class="continent-tab-btn text-xs font-label uppercase tracking-widest font-bold pb-2 border-b-2 border-transparent text-[#645D5A] hover:text-[#1C1713] transition-all duration-300 whitespace-nowrap cursor-pointer" 
              data-continent="africa"
            >
              África
            </button>
            <button 
              class="continent-tab-btn text-xs font-label uppercase tracking-widest font-bold pb-2 border-b-2 border-transparent text-[#645D5A] hover:text-[#1C1713] transition-all duration-300 whitespace-nowrap cursor-pointer" 
              data-continent="medio-oriente"
            >
              Medio Oriente
            </button>
          </div>

          <!-- Contador de Colecciones -->
          <div class="mb-8">
            <p id="continent-counter" class="font-sans text-xs uppercase tracking-wider text-[#645D5A] font-bold">Colecciones en Asia (6)</p>
          </div>

          <!-- Contenedores de Tarjetas por Continente -->
          <div class="relative w-full">
            
            <!-- ASIA GRID -->
            <div id="continent-grid-asia" class="continent-grid grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500 transform-gpu">
              {asiaCollections.map((card, index) => (
                <div 
                  class={`group flex flex-col bg-white/40 backdrop-blur-md rounded-lg overflow-hidden border border-[#1C1713]/5 hover:border-[#775A19]/25 hover:bg-white/70 transition-all duration-500 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] relative h-full reveal-up ${index >= 3 ? 'extra-card hidden' : ''}`}
                  style={index < 3 ? `transition-delay: ${index * 100}ms;` : ''}
                >
                  <div class="relative w-full aspect-[4/3] overflow-hidden">
                    <img 
                      src={card.image} 
                      alt={card.title} 
                      class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>
                  </div>
                  <div class="p-6 flex flex-col flex-grow justify-between">
                    <div>
                      <span class="block font-label text-[9px] font-bold text-[#775A19] uppercase tracking-[0.2em] mb-2">{card.subtitle}</span>
                      <h3 class="font-heading text-lg md:text-xl text-[#1C1713] mb-3 group-hover:text-[#775A19] transition-colors duration-300">{card.title}</h3>
                      <p class="font-sans text-xs text-[#645D5A] leading-relaxed mb-6">{card.description}</p>
                    </div>
                    <a href={card.link} class="inline-flex items-center gap-2 font-label text-[10px] uppercase tracking-widest text-[#775A19] font-bold group-hover:gap-4 transition-all duration-300 pb-1 w-max border-b border-transparent hover:border-[#775A19]/35">
                      Ver colección 
                      <span class="material-symbols-outlined text-xs">arrow_forward</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <!-- EUROPA GRID -->
            <div id="continent-grid-europa" class="continent-grid grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500 transform-gpu opacity-0 translate-y-4" style="display: none;">
              {europaCollections.map((card, index) => (
                <div 
                  class={`group flex flex-col bg-white/40 backdrop-blur-md rounded-lg overflow-hidden border border-[#1C1713]/5 hover:border-[#775A19]/25 hover:bg-white/70 transition-all duration-500 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] relative h-full reveal-up ${index >= 3 ? 'extra-card hidden' : ''}`}
                  style={index < 3 ? `transition-delay: ${index * 100}ms;` : ''}
                >
                  <div class="relative w-full aspect-[4/3] overflow-hidden">
                    <img 
                      src={card.image} 
                      alt={card.title} 
                      class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>
                  </div>
                  <div class="p-6 flex flex-col flex-grow justify-between">
                    <div>
                      <span class="block font-label text-[9px] font-bold text-[#775A19] uppercase tracking-[0.2em] mb-2">{card.subtitle}</span>
                      <h3 class="font-heading text-lg md:text-xl text-[#1C1713] mb-3 group-hover:text-[#775A19] transition-colors duration-300">{card.title}</h3>
                      <p class="font-sans text-xs text-[#645D5A] leading-relaxed mb-6">{card.description}</p>
                    </div>
                    <a href={card.link} class="inline-flex items-center gap-2 font-label text-[10px] uppercase tracking-widest text-[#775A19] font-bold group-hover:gap-4 transition-all duration-300 pb-1 w-max border-b border-transparent hover:border-[#775A19]/35">
                      Ver colección 
                      <span class="material-symbols-outlined text-xs">arrow_forward</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <!-- ÁFRICA GRID -->
            <div id="continent-grid-africa" class="continent-grid grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500 transform-gpu opacity-0 translate-y-4" style="display: none;">
              {africaCollections.map((card, index) => (
                <div 
                  class={`group flex flex-col bg-white/40 backdrop-blur-md rounded-lg overflow-hidden border border-[#1C1713]/5 hover:border-[#775A19]/25 hover:bg-white/70 transition-all duration-500 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] relative h-full reveal-up ${index >= 3 ? 'extra-card hidden' : ''}`}
                  style={index < 3 ? `transition-delay: ${index * 100}ms;` : ''}
                >
                  <div class="relative w-full aspect-[4/3] overflow-hidden">
                    <img 
                      src={card.image} 
                      alt={card.title} 
                      class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>
                  </div>
                  <div class="p-6 flex flex-col flex-grow justify-between">
                    <div>
                      <span class="block font-label text-[9px] font-bold text-[#775A19] uppercase tracking-[0.2em] mb-2">{card.subtitle}</span>
                      <h3 class="font-heading text-lg md:text-xl text-[#1C1713] mb-3 group-hover:text-[#775A19] transition-colors duration-300">{card.title}</h3>
                      <p class="font-sans text-xs text-[#645D5A] leading-relaxed mb-6">{card.description}</p>
                    </div>
                    <a href={card.link} class="inline-flex items-center gap-2 font-label text-[10px] uppercase tracking-widest text-[#775A19] font-bold group-hover:gap-4 transition-all duration-300 pb-1 w-max border-b border-transparent hover:border-[#775A19]/35">
                      Ver colección 
                      <span class="material-symbols-outlined text-xs">arrow_forward</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>

            <!-- MEDIO ORIENTE GRID -->
            <div id="continent-grid-medio-oriente" class="continent-grid grid grid-cols-1 md:grid-cols-3 gap-6 transition-all duration-500 transform-gpu opacity-0 translate-y-4" style="display: none;">
              {medioOrienteCollections.map((card, index) => (
                <div 
                  class={`group flex flex-col bg-white/40 backdrop-blur-md rounded-lg overflow-hidden border border-[#1C1713]/5 hover:border-[#775A19]/25 hover:bg-white/70 transition-all duration-500 shadow-[0_4px_30px_rgba(0,0,0,0.02)] hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] relative h-full reveal-up ${index >= 3 ? 'extra-card hidden' : ''}`}
                  style={index < 3 ? `transition-delay: ${index * 100}ms;` : ''}
                >
                  <div class="relative w-full aspect-[4/3] overflow-hidden">
                    <img 
                      src={card.image} 
                      alt={card.title} 
                      class="w-full h-full object-cover transition-transform duration-[2000ms] ease-out group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>
                  </div>
                  <div class="p-6 flex flex-col flex-grow justify-between">
                    <div>
                      <span class="block font-label text-[9px] font-bold text-[#775A19] uppercase tracking-[0.2em] mb-2">{card.subtitle}</span>
                      <h3 class="font-heading text-lg md:text-xl text-[#1C1713] mb-3 group-hover:text-[#775A19] transition-colors duration-300">{card.title}</h3>
                      <p class="font-sans text-xs text-[#645D5A] leading-relaxed mb-6">{card.description}</p>
                    </div>
                    <a href={card.link} class="inline-flex items-center gap-2 font-label text-[10px] uppercase tracking-widest text-[#775A19] font-bold group-hover:gap-4 transition-all duration-300 pb-1 w-max border-b border-transparent hover:border-[#775A19]/35">
                      Ver colección 
                      <span class="material-symbols-outlined text-xs">arrow_forward</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>

          </div>

          <!-- Enlace inferior dinámico -->
          <div class="mt-14 text-center">
            <a 
              id="view-all-continent-link" 
              href="/universos/asia" 
