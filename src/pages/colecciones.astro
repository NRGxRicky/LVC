<script>
  // ── SCRIPT DE PESTAÑAS E INTERACTIVIDAD DE CONTINENTES ──
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.continent-tab-btn');
    const grids = document.querySelectorAll('.continent-grid');
    const counter = document.getElementById('continent-counter');
    const viewAllLink = document.getElementById('view-all-continent-link');
    
    const continentNames: Record<string, string> = {
      asia: 'Asia',
      europa: 'Europa',
      africa: 'África',
      'medio-oriente': 'Medio Oriente'
    };

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const targetContinent = tab.getAttribute('data-continent');
        if (!targetContinent) return;

        // 1. Actualizar estado visual de los botones de pestañas
        tabs.forEach(t => {
          t.classList.remove('active', 'border-[#775A19]', 'text-[#775A19]');
          t.classList.add('border-transparent', 'text-[#645D5A]');
        });
        tab.classList.add('active', 'border-[#775A19]', 'text-[#775A19]');
        tab.classList.remove('border-transparent', 'text-[#645D5A]');

        // 2. Actualizar el contador de colecciones
        if (counter) {
          counter.textContent = `Colecciones en ${continentNames[targetContinent]} (6)`;
        }

        // 3. Actualizar enlace inferior y restablecer su visibilidad
        if (viewAllLink) {
          viewAllLink.setAttribute('href', `/universos/${targetContinent}`);
          viewAllLink.innerHTML = `
            VER TODAS LAS COLECCIONES EN ${continentNames[targetContinent].toUpperCase()}
            <span class="material-symbols-outlined text-xs group-hover:translate-x-1 transition-transform duration-300">arrow_forward</span>
          `;
          viewAllLink.style.display = 'inline-flex';
          void viewAllLink.offsetWidth;
          viewAllLink.classList.remove('opacity-0', 'pointer-events-none');
        }

        // 4. Cambiar de cuadrícula con efecto de transición (fade & slide)
        grids.forEach(grid => {
          const htmlGrid = grid as HTMLElement;
          if (grid.id === `continent-grid-${targetContinent}`) {
            htmlGrid.style.display = 'grid';

            // Ocultar tarjetas extra en la cuadrícula que se activa
            const extraCards = htmlGrid.querySelectorAll('.extra-card');
            extraCards.forEach(card => {
              card.classList.add('hidden');
              card.classList.remove('is-revealed');
              (card as HTMLElement).style.transitionDelay = '';
            });

            // Forzar reflow del navegador para aplicar animación
            void htmlGrid.offsetWidth;
            htmlGrid.classList.remove('opacity-0', 'translate-y-4');
            htmlGrid.classList.add('opacity-100', 'translate-y-0');
            
            // Re-ejecutar animaciones reveal en las tarjetas no-extra de la pestaña activa
            const reveals = htmlGrid.querySelectorAll('.reveal-up:not(.extra-card)');
            reveals.forEach((el, index) => {
              setTimeout(() => {
                el.classList.add('is-revealed');
              }, index * 100);
            });
          } else {
            // Ocultar inmediatamente para evitar que se apilen y causen saltos de layout (layout shift)
            htmlGrid.style.display = 'none';
            htmlGrid.classList.add('opacity-0', 'translate-y-4');
            htmlGrid.classList.remove('opacity-100', 'translate-y-0');
          }
        });
      });
    });

    // ── EVENTO CLIC EN EL BOTÓN "VER TODAS LAS COLECCIONES..." ──
    if (viewAllLink) {
      viewAllLink.addEventListener('click', (e) => {
        // En lugar de redirigir, mostramos las colecciones ocultas
        e.preventDefault();

        // Encontrar la pestaña activa para saber qué continente está visible
        const activeTab = document.querySelector('.continent-tab-btn.active');
        if (!activeTab) return;
        const targetContinent = activeTab.getAttribute('data-continent');
        if (!targetContinent) return;

        const activeGrid = document.getElementById(`continent-grid-${targetContinent}`);
        if (!activeGrid) return;

        const extraCards = activeGrid.querySelectorAll('.extra-card');
        
        extraCards.forEach((card, index) => {
          // Remover class hidden para que aparezcan en el layout del grid
          card.classList.remove('hidden');
          // Quitar is-revealed temporalmente por si acaso
          card.classList.remove('is-revealed');
          // Aplicar retraso de transición escalonado
          (card as HTMLElement).style.transitionDelay = `${index * 150}ms`;
        });

        // Forzar reflow para aplicar la transición de opacidad y posición
        void activeGrid.offsetWidth;

        extraCards.forEach((card) => {
          // Activar animación
          card.classList.add('is-revealed');
        });

        // Ocultar suavemente el botón
        viewAllLink.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => {
          viewAllLink.style.display = 'none';
        }, 500); // Duración de la transición opacity
      });
    }

    // ── EFECTO PARALLAX EN LA INTRODUCCIÓN EDITORIAL ──
    const gateway = document.getElementById('parallax-gateway');
    const hills = document.getElementById('parallax-hills');
    
    if (gateway && hills) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        // Ajustamos la velocidad para cada imagen (uno sube despacio, otro baja)
        gateway.style.transform = `translateY(${scrolled * 0.05}px)`;
        hills.style.transform = `translateY(${scrolled * -0.06}px)`;
      }, { passive: true });
    }

    // ── CARRUSEL INTERACTIVO DE COLECCIÓN DESTACADA ──
    const featuredSlides = [
      {
        title: "Senderos de Japón",
        description: "Entre antiguas rutas, ciudades históricas y paisajes que aún conservan otro ritmo.",
        image: "https://garage-web.luxuryvoyageco.com/images/colecciones/featured_japan.webp",
        link: "/colecciones/senderos-de-japon"
      },
      {
        title: "Tierras del Reino",
        description: "Tres naciones unidas por historia, paisajes y tradiciones en un recorrido exclusivo de súper lujo por Inglaterra, Escocia e Irlanda.",
        image: "https://garage-web.luxuryvoyageco.com/images/universos/europa/escenarios/escocia.webp",
        link: "/colecciones/tierras-del-reino"
      },
      {
        title: "Safari de Lujo",
        description: "Vive la magia del Serengueti con la máxima exclusividad: guías de primer nivel, campamentos cinco estrellas en carpas tradicionales y atardeceres mágicos.",
        image: "https://garage-web.luxuryvoyageco.com/images/hero_carousel/africa.webp",
        link: "/colecciones/safari-lujo"
      },
      {
        title: "Petra Secreta",
        description: "Cruza el desfiladero del Siq en coche privado y asómate al Tesoro de Petra iluminado por velas, finalizando en un campamento de domos en Wadi Rum.",
        image: "https://garage-web.luxuryvoyageco.com/images/hero_carousel/medio_oriente.webp",
        link: "/colecciones/petra-secreta"
      }
    ];

    let currentFeaturedIndex = 0;
    const featImage = document.getElementById('featured-carousel-image') as HTMLImageElement;
    const featTitle = document.getElementById('featured-carousel-title');
    const featDesc = document.getElementById('featured-carousel-description');
    const featLink = document.getElementById('featured-carousel-link');
    const prevBtn = document.getElementById('featured-prev-btn');
    const nextBtn = document.getElementById('featured-next-btn');

    function updateFeaturedSlide(index: number) {
      if (!featImage || !featTitle || !featDesc || !featLink) return;
      const slide = featuredSlides[index];

      // Animación de salida (fade out suave)
      featTitle.classList.add('opacity-0', 'translate-y-2');
      featDesc.classList.add('opacity-0', 'translate-y-2');
      featImage.classList.add('opacity-80', 'scale-95');

      setTimeout(() => {
        // Actualizar datos
        featTitle.textContent = slide.title;
        featDesc.textContent = slide.description;
        featImage.src = slide.image;
        featImage.alt = slide.title;
        featLink.setAttribute('href', slide.link);

        // Animación de entrada (fade in suave)
        featTitle.classList.remove('opacity-0', 'translate-y-2');
        featDesc.classList.remove('opacity-0', 'translate-y-2');
        featImage.classList.remove('opacity-80', 'scale-95');
        featImage.classList.add('scale-100');
      }, 300);
    }

    // Temporizador de Auto-play (5 segundos)
    let autoPlayInterval = setInterval(() => {
      currentFeaturedIndex = (currentFeaturedIndex + 1) % featuredSlides.length;
      updateFeaturedSlide(currentFeaturedIndex);
    }, 5000);

    // Reiniciar temporizador al hacer click manual
    function resetAutoPlay() {
      clearInterval(autoPlayInterval);
      autoPlayInterval = setInterval(() => {
        currentFeaturedIndex = (currentFeaturedIndex + 1) % featuredSlides.length;
        updateFeaturedSlide(currentFeaturedIndex);
      }, 5000);
    }

    prevBtn?.addEventListener('click', () => {
      currentFeaturedIndex = (currentFeaturedIndex - 1 + featuredSlides.length) % featuredSlides.length;
      updateFeaturedSlide(currentFeaturedIndex);
      resetAutoPlay();
    });

    nextBtn?.addEventListener('click', () => {
      currentFeaturedIndex = (currentFeaturedIndex + 1) % featuredSlides.length;
      updateFeaturedSlide(currentFeaturedIndex);
      resetAutoPlay();
    });
  });
</script>

<style>
  /* Ocultar barra de scroll en navegadores */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Clases de transición para el carrusel de colección destacada */
  #featured-carousel-title,
  #featured-carousel-description {
    transition: opacity 0.35s cubic-bezier(0.25, 1, 0.5, 1), transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }
</style>
