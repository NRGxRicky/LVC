  },
  {
    title: "La Herencia de Alemania",
    subtitle: "BAVIERA Y SELVA NEGRA",
    description: "Una ruta entre ciudades históricas, bosques legendarios y castillos que marcaron la identidad de Baviera.",
    image: "https://images.unsplash.com/photo-1467269204594-9661b134dd2b?q=80&w=600&auto=format&fit=crop",
