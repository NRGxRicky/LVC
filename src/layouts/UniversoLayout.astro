---

<Layout title={title} description={description}>
  <Navbar />

  <main class="w-full bg-[#EDE7D7]">
    
    <!-- HERO -->
    <section class="relative w-full h-screen min-h-[70vh] flex items-center justify-start overflow-hidden">
      <div class="absolute inset-0 z-0">
        <picture class="absolute inset-0 w-full h-full">
          {heroImageMobile && (
            <source 
              media="(max-width: 768px)" 
              srcset={heroImageMobile}
            />
          )}
          <img 
            src={heroImage} 
            alt={`Paisaje de ${heroTitle}`} 
            class="w-full h-full object-cover object-[50%_70%]"
          />
        </picture>
        <div class="absolute inset-0 bg-gradient-to-r from-[#1C1713]/80 via-[#1C1713]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-80% to-[#EDE7D7]"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 md:pl-24 pt-32 pb-24 flex flex-col items-start h-full justify-center">
        <span class="block font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em] mb-4">
          {activeLabel}
        </span>
        <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
        
        <h1 class="font-heading text-4xl md:text-5xl lg:text-[4rem] text-white leading-[1.25] mb-8 text-left" set:html={activeTitleHtml}>
        </h1>
        
        <a 
          href="#lugares" 
          class="flex items-center gap-3 font-label text-xs uppercase tracking-widest text-white/80 hover:text-[#D4AD65] transition-colors duration-300 group border-b border-white/20 hover:border-[#D4AD65] pb-2"
        >
          Ver todos los destinos &nbsp;&rarr;
        </a>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
            <div class="w-5 h-8 border border-white/30 rounded-full flex justify-center p-1">
                <div class="w-1 h-2 bg-white rounded-full animate-bounce"></div>
            </div>
            <span class="font-label text-[10px] uppercase tracking-widest text-white/50">Scroll</span>
        </div>
      </div>
    </section>

    <!-- LUGARES QUE INSPIRAN (CAROUSEL) -->
    <section id="lugares" class="w-full bg-[#EDE7D7] px-6 md:px-12 py-20 md:py-32 overflow-hidden">
        <div class="max-w-[1920px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-8">
            
            <!-- Left Info Column -->
            <div class="w-full lg:w-[28%] flex flex-col justify-between py-2">
              <div>
                <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">ESCENARIOS</span>
                <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
                <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-[1.25]">
                  Donde la <span class="italic text-[#775A19] font-serif">esencia</span><br class="hidden lg:block" />
                  se vuelve lugar.
                </h2>
              </div>
              <div class="mt-8 lg:mt-0">
                <a 
                  href="/contacto" 
                  class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
                >
                  Ver todos los destinos &nbsp;&rarr;
                </a>
              </div>
            </div>

            <!-- Right Carousel Column -->
            <div class="w-full lg:w-[72%]">
              <div class="relative group/carousel">
                <!-- Swiper Container -->
                <div class="swiper placesSwiper overflow-hidden pb-4">
                  <div class="swiper-wrapper">
                    {lugares.map((lugar) => (
                      <div class="swiper-slide">
                        <a 
                          href="/contacto" 
                          data-modal-trigger
                          data-place-name={lugar.name}
                          data-continent={heroTitle}
                          data-continent-slug={slug}
                          class="group relative block aspect-[2/3] overflow-hidden bg-[#1C1713] cursor-pointer rounded-[2rem]"
                        >
                          <Image 
                            src={lugar.image} 
                            alt={lugar.name}
                            width={450}
                            height={675}
                            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-80 group-hover:opacity-100"
                          />
                          <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713]/90 via-[#1C1713]/25 to-transparent"></div>
                          
                          <div class="absolute bottom-0 left-0 w-full p-6 md:p-8 flex items-end justify-between gap-4 z-10 text-left">
                            <div class="flex-1 min-w-0">
                              <h3 class="font-heading text-xl md:text-2xl lg:text-3xl text-white mb-1.5 md:mb-2 tracking-wide leading-tight">{formatPlaceName(lugar.name)}</h3>
                              <p class="font-sans text-[11px] md:text-xs text-white/80 leading-relaxed max-w-[85%]">
                                {lugar.desc}
                              </p>
                            </div>
                            
                            <!-- Circle Arrow Button -->
                            <div class="w-9 h-9 md:w-10 md:h-10 rounded-full border border-white/30 flex items-center justify-center text-white/85 group-hover:border-white group-hover:text-white group-hover:bg-white/10 transition-all duration-300 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                              </svg>
                            </div>
                          </div>
                        </a>
                      </div>
                    ))}
                  </div>
                </div>

                <!-- Controles y Barra de Progreso para Escenarios -->
                <div class="flex flex-col md:flex-row items-center justify-between gap-6 mt-6 pt-6 border-t border-[#1C1713]/10">
                    <!-- Botones de Navegación -->
                    <div class="flex items-center gap-6 font-label text-[11px] tracking-[0.2em] text-[#775A19] shrink-0">
                        <button id="placesPrevBtn" class="hover:text-[#1C1713] transition-colors cursor-pointer flex items-center gap-1 font-bold">
                            &lt; ANTERIOR
                        </button>
                        <span id="placesCounter" class="text-[#1C1713]/40 font-mono">1 / {lugares.length}</span>
                        <button id="placesNextBtn" class="hover:text-[#1C1713] transition-colors cursor-pointer flex items-center gap-1 font-bold">
                            SIGUIENTE &gt;
                        </button>
                    </div>
                    
                    <!-- Barra de Progreso (Manejada por Swiper) -->
                    <div class="w-full max-w-[500px]">
                        <div class="places-swiper-pagination swiper-pagination"></div>
                    </div>
                </div>
              </div>
            </div>

          </div>
        </div>
    </section>

    <slot />

    <!-- EXPERIENCIAS QUE TRANSFORMAN -->
    <section class="experiences-section w-full bg-[#EDE7D7] py-20 md:py-32 overflow-hidden">
      <div class="max-w-[1920px] mx-auto">
        <div class="experiences-title-container text-center mb-12 md:mb-16 px-6">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#775A19] uppercase tracking-widest block mb-4">MOMENTOS DEL VIAJE</span>
          <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] mb-4">Donde el viaje cobra <span class="italic text-[#D4AD65]">sentido</span></h2>
          <div class="w-10 h-[1px] bg-[#D4AD65] mx-auto mb-8"></div>
        </div>

        <!-- Slider/Carousel Container (Ritz-Carlton Centered Layout) -->
        <div class="relative w-full overflow-hidden">
          <!-- Fade-out Masks (Ritz-Carlton style) -->
          <div class="absolute left-0 top-0 bottom-0 w-12 sm:w-24 md:w-64 bg-gradient-to-r from-[#EDE7D7] to-transparent pointer-events-none z-20"></div>
          <div class="absolute right-0 top-0 bottom-0 w-12 sm:w-24 md:w-64 bg-gradient-to-l from-[#EDE7D7] to-transparent pointer-events-none z-20"></div>

          <!-- Carousel viewport -->
          <div class="w-full overflow-hidden py-4 px-4 md:px-0">
            <div 
              id="experiences-carousel-track"
              class="flex gap-6 md:gap-8 transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]"
              style="transform: translateX(0px);"
            >
              {experiencias.map((exp, i) => {
                const gallery = (experienceImages[slug] && experienceImages[slug][i]) || [exp.image];
                return (
                  <div 
                    class="experience-slide group relative flex-none w-[280px] sm:w-[320px] md:w-[450px] aspect-[2/3] md:aspect-[2/3] overflow-hidden rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.15)] transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] origin-center cursor-pointer scale-90 opacity-40"
                    data-experience-trigger
                    data-category-index={i}
                    data-category-name={exp.name}
                    data-universe-slug={slug}
                  >
                    <!-- Gallery Images -->
                    {gallery.map((imgUrl, imgIdx) => (
                      <img 
                        src={imgUrl} 
                        alt={`${exp.name} - ${imgIdx + 1}`}
                        class={`gallery-image absolute inset-0 w-full h-full object-cover transition-all duration-[1500ms] ease-in-out group-hover:scale-110 ${imgIdx === 0 ? "opacity-100" : "opacity-0"}`}
                        loading="eager"
                      />
                    ))}
                    <!-- Dark Gradient Overlay for readability -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/30 to-black/10 z-10"></div>
                    
                    <!-- Text Content Inside Card (Bottom-Left) -->
                    <div class="slide-text-container absolute bottom-6 left-6 right-6 md:bottom-8 md:left-8 md:right-8 z-20 text-left">
                      <h3 class="font-heading text-xl md:text-2xl lg:text-3xl text-[#FAF9F6] tracking-wider uppercase mb-2 leading-tight">
                        {exp.name}
                      </h3>
                      <p class="font-sans text-[11px] md:text-xs lg:text-sm text-white/80 mb-4 max-w-[90%] leading-relaxed hidden sm:block">
                        {exp.desc}
                      </p>
                      <span class="inline-block font-label text-[10px] md:text-xs uppercase tracking-widest text-[#D4AD65] border-b border-[#D4AD65]/50 pb-0.5 transition-colors duration-300">
                        SABER MÁS
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Custom Navigation & Progress Bar -->
        <div class="flex flex-col items-center gap-6 mt-10 px-6">
          <!-- Progress Line (Fina, 1px) -->
          <div class="w-full max-w-[280px] sm:max-w-[360px] h-[1px] bg-[#775A19]/15 relative overflow-hidden">
            <div id="experience-progress-bar" class="absolute top-0 left-0 h-full bg-[#775A19] transition-all duration-700" style="width: 33.333%;"></div>
          </div>

          <!-- Botones de Navegación y Contador alineados horizontalmente -->
          <div class="flex items-center gap-8 font-label text-[10px] md:text-xs uppercase tracking-[0.2em] text-[#775A19]">
            <button id="prev-experience" class="hover:text-[#1C1713] transition-colors cursor-pointer flex items-center gap-1 font-bold">
              &lt; ANTERIOR
            </button>
            
            <span id="experience-counter" class="text-[#1C1713]/40 font-mono text-xs px-4 border-l border-r border-[#775A19]/15">
              1 / 3
            </span>
            
            <button id="next-experience" class="hover:text-[#1C1713] transition-colors cursor-pointer flex items-center gap-1 font-bold">
              SIGUIENTE &gt;
            </button>
          </div>
        </div>

        <div class="mt-14 md:mt-20 text-center px-6">
          <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] mb-8">Tu experiencia en <span class="text-[#D4AD65] italic">{heroTitle}</span> comienza con una <span class="text-[#D4AD65] italic">decisión</span>.</h2>
          <a 
            href="/contacto" 
