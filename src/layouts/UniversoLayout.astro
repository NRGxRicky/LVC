        </div>

        <!-- Track / Carrusel de Tarjetas -->
        <div class="relative w-full overflow-hidden my-4 max-w-6xl mx-auto">
          <!-- Flecha de Navegación Izquierda -->
          <button id="modal-prev-btn" class="absolute left-2 md:-left-6 top-1/2 -translate-y-1/2 w-11 h-11 rounded-full bg-white shadow-md border border-[#1C1713]/10 flex items-center justify-center text-[#1C1713] hover:bg-[#EDE7D7] transition-all duration-300 cursor-pointer z-20 hidden">
