        width: 360px !important;
        height: 540px !important; /* aspect 2/3 */
      }
    }

    @media (max-height: 720px) {
      .experiences-section {
        padding-top: 3.5rem !important;
        padding-bottom: 3.5rem !important;
      }
      .experiences-title-container {
        margin-bottom: 1.5rem !important;
      }
      .experiences-section .experience-slide {
        width: 300px !important;
        height: 450px !important; /* aspect 2/3 */
      }
    }
  }

  /* Ocultar el texto en las tarjetas de experiencias no seleccionadas */
  .experiences-section .experience-slide .slide-text-container {
    opacity: 0 !important;
    transform: translateY(10px);
    transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .experiences-section .experience-slide.opacity-100 .slide-text-container {
    opacity: 1 !important;
    transform: translateY(0);
