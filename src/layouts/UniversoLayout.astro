---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";

export interface Lugar {
  name: string;
  desc: string;
  image: string;
}

export interface Experiencia {
  name: string;
  desc: string;
  image: string;
}

export interface Props {
  title: string;
  description: string;
  slug: string;
  heroTitle: string;
  heroImage: string;
  heroDesc: string;
  splitImage: string;
  lugares: Lugar[];
  experiencias: Experiencia[];
}

const {
  title,
  description,
  slug,
  heroTitle,
  heroImage,
  heroDesc,
  splitImage,
  lugares,
  experiencias
} = Astro.props;

const labels: Record<string, string> = {
  asia: "Universo Asia",
  africa: "Universo África",
  europa: "Universo Europa",
  "medio-oriente": "Universo Medio Oriente"
};

const titles: Record<string, string> = {
  asia: `La belleza de la<br />
    <span class="text-[#D4AD65] italic font-serif">armonía</span> entre<br />
    contrastes.`,
  africa: `El arte de vivir<br />
    aquello que <span class="text-[#D4AD65] italic font-serif">transforma</span>.`,
  europa: `Donde cada detalle<br />
    refleja lo <span class="text-[#D4AD65] italic font-serif">atemporal</span>.`,
  "medio-oriente": `Una visión marcada<br />
    por lo <span class="text-[#D4AD65] italic font-serif">extraordinario</span>.`
};

const activeLabel = labels[slug] || `Universo ${heroTitle}`;
const activeTitleHtml = titles[slug] || heroDesc;

function formatPlaceName(name: string) {
  return name
    .toLowerCase()
    .split(" ")
    .map(word => {
      if (["del", "de", "y", "e", "o"].includes(word)) return word;
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join(" ");
}

const experienceImages: Record<string, string[][]> = {
  asia: [
    [
      "https://garage-web.luxuryvoyageco.com/images/asia_cena_1776311284263.png",
      "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=1000&q=80",
      "https://images.unsplash.com/photo-1552611052-33e04de081de?w=1000&q=80",
      "https://images.unsplash.com/photo-1563245372-f21724e3856d?w=1000&q=80",
      "https://images.unsplash.com/photo-1544025162-d76694265947?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/asia_villas_1776311298395.png",
      "https://images.unsplash.com/photo-1583037189850-1921ae7c6c22?w=1000&q=80",
      "https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1000&q=80",
      "https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=1000&q=80",
      "https://images.unsplash.com/photo-1566665797739-1674de7a421a?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/asia_spa_1776311310552.png",
      "https://images.unsplash.com/photo-1545569341-9eb8b30979d9?w=1000&q=80",
      "https://images.unsplash.com/photo-1528127269322-539801943592?w=1000&q=80",
      "https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1000&q=80",
      "https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?w=1000&q=80"
    ]
  ],
  europa: [
    [
      "https://garage-web.luxuryvoyageco.com/images/europa_gastro.png",
      "https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?w=1000&q=80",
      "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1000&q=80",
      "https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=1000&q=80",
      "https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/europa_arte.png",
      "https://images.unsplash.com/photo-1618773928121-c32242e63f39?w=1000&q=80",
      "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1000&q=80",
      "https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=1000&q=80",
      "https://images.unsplash.com/photo-1582719508461-905c673771fd?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/europa_chateau.png",
      "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1000&q=80",
      "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1000&q=80",
      "https://images.unsplash.com/photo-1498503182468-3b51cbb6cb24?w=1000&q=80",
      "https://images.unsplash.com/photo-1486806848873-f519550fc41b?w=1000&q=80"
    ]
  ],
  africa: [
    [
      "https://garage-web.luxuryvoyageco.com/images/africa_safari.png",
      "https://images.unsplash.com/photo-1544025162-d76694265947?w=1000&q=80",
      "https://images.unsplash.com/photo-1510812431401-41d2bd2722f3?w=1000&q=80",
      "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1000&q=80",
      "https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/africa_lodge.png",
      "https://images.unsplash.com/photo-1549366021-9f761d450615?w=1000&q=80",
      "https://images.unsplash.com/photo-1577971132997-c10be9372519?w=1000&q=80",
      "https://images.unsplash.com/photo-1582719508461-905c673771fd?w=1000&q=80",
      "https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/africa_cena.png",
      "https://images.unsplash.com/photo-1516426122078-c23e76319801?w=1000&q=80",
      "https://images.unsplash.com/photo-1516026672322-bc52d61a55d5?w=1000&q=80",
      "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1000&q=80",
      "https://images.unsplash.com/photo-1533105079780-92b9be482077?w=1000&q=80"
    ]
  ],
  "medio-oriente": [
    [
      "https://garage-web.luxuryvoyageco.com/images/oriente_mid.png",
      "https://images.unsplash.com/photo-1544025162-d76694265947?w=1000&q=80",
      "https://images.unsplash.com/photo-1563245372-f21724e3856d?w=1000&q=80",
      "https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?w=1000&q=80",
      "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/oriente_dubai.png",
      "https://images.unsplash.com/photo-1582719508461-905c673771fd?w=1000&q=80",
      "https://images.unsplash.com/photo-1540555700478-4be289fbecef?w=1000&q=80",
      "https://images.unsplash.com/photo-1590490360182-c33d57733427?w=1000&q=80",
      "https://images.unsplash.com/photo-1618773928121-c32242e63f39?w=1000&q=80"
    ],
    [
      "https://garage-web.luxuryvoyageco.com/images/asia_cena_1776311284263.png",
      "https://images.unsplash.com/photo-1547234935-80c7145ec969?w=1000&q=80",
      "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1000&q=80",
      "https://images.unsplash.com/photo-1533105079780-92b9be482077?w=1000&q=80",
      "https://images.unsplash.com/photo-1528127269322-539801943592?w=1000&q=80"
    ]
  ]
};
---

<Layout title={title} description={description}>
  <Navbar />

  <main class="w-full bg-[#EDE7D7]">
    
    <!-- HERO -->
    <section class="relative w-full h-screen min-h-[70vh] flex items-center justify-start overflow-hidden">
      <div class="absolute inset-0 z-0">
        <Image 
          src={heroImage} 
          alt={`Paisaje de ${heroTitle}`} 
          width={1920}
          height={1080}
          class="w-full h-full object-cover object-[50%_70%]"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#1C1713]/80 via-[#1C1713]/40 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent via-50% to-[#EDE7D7]"></div>
      </div>
      
      <div class="relative z-10 w-full max-w-[1920px] mx-auto px-6 md:px-12 md:pl-24 pt-32 pb-24 flex flex-col items-start h-full justify-center">
        <span class="block font-label text-[10px] md:text-xs font-bold text-[#D4AD65] uppercase tracking-[0.3em] mb-4">
          {activeLabel}
        </span>
        <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
        
        <h1 class="font-heading text-4xl md:text-5xl lg:text-[4rem] text-white leading-[1.25] mb-8 text-left" set:html={activeTitleHtml}>
        </h1>
        
        <a 
          href="#lugares" 
          class="flex items-center gap-3 font-label text-xs uppercase tracking-widest text-white/80 hover:text-[#D4AD65] transition-colors duration-300 group border-b border-white/20 hover:border-[#D4AD65] pb-2"
        >
          Ver todos los destinos &nbsp;&rarr;
        </a>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
            <div class="w-5 h-8 border border-white/30 rounded-full flex justify-center p-1">
                <div class="w-1 h-2 bg-white rounded-full animate-bounce"></div>
            </div>
            <span class="font-label text-[10px] uppercase tracking-widest text-white/50">Scroll</span>
        </div>
      </div>
    </section>

    <!-- LUGARES QUE INSPIRAN (CAROUSEL) -->
    <section id="lugares" class="w-full bg-[#EDE7D7] px-6 md:px-12 py-20 md:py-32 overflow-hidden">
        <div class="max-w-[1920px] mx-auto">
          <div class="flex flex-col lg:flex-row gap-12 lg:gap-8">
            
            <!-- Left Info Column -->
            <div class="w-full lg:w-[28%] flex flex-col justify-between py-2">
              <div>
                <span class="block font-label text-[10px] font-bold text-[#775A19] uppercase tracking-widest mb-3">ESCENARIOS</span>
                <div class="w-10 h-[1px] bg-[#D4AD65] mb-6"></div>
                <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] leading-[1.25]">
                  Donde la <span class="italic text-[#775A19] font-serif">esencia</span><br class="hidden lg:block" />
                  se vuelve lugar.
                </h2>
              </div>
              <div class="mt-8 lg:mt-0">
                <a 
                  href="/contacto" 
                  class="inline-flex items-center gap-3 font-label text-xs uppercase tracking-widest text-[#775A19] hover:text-[#1C1713] font-bold border-b border-[#D4AD65] pb-2 transition-colors duration-300 group"
                >
                  Ver todos los destinos &nbsp;&rarr;
                </a>
              </div>
            </div>

            <!-- Right Carousel Column -->
            <div class="w-full lg:w-[72%]">
              <div class="relative group/carousel">
                <!-- Swiper Container -->
                <div class="swiper placesSwiper overflow-hidden pb-12">
                  <div class="swiper-wrapper">
                    {lugares.map((lugar) => (
                      <div class="swiper-slide">
                        <a 
                          href="/contacto" 
                          class="group relative block aspect-[3/4] overflow-hidden bg-[#1C1713] cursor-pointer"
                        >
                          <Image 
                            src={lugar.image} 
                            alt={lugar.name}
                            width={450}
                            height={600}
                            class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-[1.08] opacity-80 group-hover:opacity-100"
                          />
                          <div class="absolute inset-0 bg-gradient-to-t from-[#1C1713]/90 via-[#1C1713]/25 to-transparent"></div>
                          
                          <div class="absolute bottom-0 left-0 w-full p-8 flex items-end justify-between gap-4 z-10">
                            <div class="flex flex-col">
                              <h3 class="font-heading text-2xl text-white mb-2 tracking-wide">{formatPlaceName(lugar.name)}</h3>
                              <p class="font-sans text-xs text-white/80 leading-relaxed max-w-[210px]">
                                {lugar.desc}
                              </p>
                            </div>
                            
                            <!-- Circle Arrow Button -->
                            <div class="w-10 h-10 rounded-full border border-white/30 flex items-center justify-center text-white/85 group-hover:border-white group-hover:text-white group-hover:bg-white/10 transition-all duration-300 shrink-0">
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                              </svg>
                            </div>
                          </div>
                        </a>
                      </div>
                    ))}
                  </div>
                  
                  <!-- progress bar -->
                  <div class="places-swiper-pagination swiper-pagination !bottom-0"></div>
                </div>

                <!-- Absolute Navigation Arrows -->
                <button 
                  id="swiperPrev" 
                  class="absolute left-0 top-0 bottom-12 w-[12%] z-20 flex items-center justify-start pl-4 opacity-0 hover:opacity-100 transition-opacity duration-500 cursor-pointer"
                  aria-label="Anterior"
                >
                  <div class="w-10 h-10 rounded-full bg-[#1C1713]/85 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white hover:border-[#D4AD65] hover:text-[#D4AD65] transition-all duration-300 shadow-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                  </div>
                </button>
                <button 
                  id="swiperNext" 
                  class="absolute right-0 top-0 bottom-12 w-[12%] z-20 flex items-center justify-end pr-4 opacity-0 hover:opacity-100 transition-opacity duration-500 cursor-pointer"
                  aria-label="Siguiente"
                >
                  <div class="w-10 h-10 rounded-full bg-[#1C1713]/85 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white hover:border-[#D4AD65] hover:text-[#D4AD65] transition-all duration-300 shadow-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </div>
                </button>
              </div>
            </div>

          </div>
        </div>
    </section>

    <slot />

    <!-- EXPERIENCIAS QUE TRANSFORMAN -->
    <section class="w-full bg-[#EDE7D7] py-20 md:py-32 overflow-hidden">
      <div class="max-w-[1920px] mx-auto">
        <div class="text-center mb-12 md:mb-16 px-6">
          <span class="font-label text-[10px] md:text-xs font-bold text-[#775A19] uppercase tracking-widest block mb-4">MOMENTOS DEL VIAJE</span>
          <h2 class="font-heading text-4xl md:text-5xl text-[#1C1713] mb-4">Donde el viaje cobra <span class="italic text-[#D4AD65]">sentido</span></h2>
          <div class="w-10 h-[1px] bg-[#D4AD65] mx-auto mb-8"></div>
        </div>

        <!-- Slider/Carousel Container (Ritz-Carlton Centered Layout) -->
        <div class="relative w-full overflow-hidden">
          <!-- Fade-out Masks (Ritz-Carlton style) -->
          <div class="absolute left-0 top-0 bottom-0 w-12 sm:w-24 md:w-64 bg-gradient-to-r from-[#EDE7D7] to-transparent pointer-events-none z-20"></div>
          <div class="absolute right-0 top-0 bottom-0 w-12 sm:w-24 md:w-64 bg-gradient-to-l from-[#EDE7D7] to-transparent pointer-events-none z-20"></div>

          <!-- Carousel viewport -->
          <div class="w-full overflow-hidden py-4 px-4 md:px-0">
            <div 
              id="experiences-carousel-track"
              class="flex gap-6 md:gap-8 transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)]"
              style="transform: translateX(0px);"
            >
              {experiencias.map((exp, i) => {
                const gallery = (experienceImages[slug] && experienceImages[slug][i]) || [exp.image];
                return (
                  <div 
                    class="experience-slide group relative flex-none w-[280px] sm:w-[350px] md:w-[600px] aspect-[4/3] md:aspect-[16/10] overflow-hidden rounded-xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] origin-center cursor-pointer scale-90 opacity-40"
                  >
                    <!-- Gallery Images -->
                    {gallery.map((imgUrl, imgIdx) => (
                      <img 
                        src={imgUrl} 
                        alt={`${exp.name} - ${imgIdx + 1}`}
                        class={`gallery-image absolute inset-0 w-full h-full object-cover transition-all duration-[1500ms] ease-in-out group-hover:scale-110 ${imgIdx === 0 ? "opacity-100" : "opacity-0"}`}
                        loading="lazy"
                      />
                    ))}
                    <!-- Dark Gradient Overlay for readability -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 z-10"></div>
                    
                    <!-- Text Content Inside Card (Bottom-Left) -->
                    <div class="absolute bottom-8 left-8 right-8 z-20 text-left">
                      <h3 class="font-heading text-xl md:text-3xl text-[#FAF9F6] tracking-wider uppercase mb-2 leading-tight">
                        {formatPlaceName(exp.name)}
                      </h3>
                      <p class="font-sans text-xs md:text-sm text-white/80 mb-4 max-w-sm md:max-w-md leading-relaxed hidden sm:block">
                        {exp.desc}
                      </p>
                      <span class="inline-block font-label text-[10px] md:text-xs uppercase tracking-widest text-[#D4AD65] border-b border-[#D4AD65]/50 pb-0.5 transition-colors duration-300">
                        Saber más
                      </span>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Custom Navigation & Progress Bar -->
        <div class="flex flex-col items-center gap-4 mt-8 px-6">
          <div class="flex items-center gap-6 sm:gap-8 font-label text-[10px] md:text-xs uppercase tracking-widest text-[#1C1713]">
            <button id="prev-experience" class="hover:text-[#775A19] transition-colors cursor-pointer flex items-center gap-1 font-bold">
              &lt; Anterior
            </button>
            
            <!-- Progress Line -->
            <div class="w-32 sm:w-48 h-[2px] bg-[#1C1713]/10 relative overflow-hidden rounded-full">
              <div id="experience-progress-bar" class="absolute top-0 left-0 h-full bg-[#775A19] transition-all duration-700 rounded-full" style="width: 33.333%;"></div>
            </div>
            
            <button id="next-experience" class="hover:text-[#775A19] transition-colors cursor-pointer flex items-center gap-1 font-bold">
              Siguiente &gt;
            </button>
          </div>
          
          <!-- Counter -->
          <div id="experience-counter" class="font-label text-[10px] md:text-xs text-[#1C1713]/60 tracking-wider">
            1 / 3
          </div>
        </div>
        
        <div class="mt-14 md:mt-20 text-center px-6">
          <h2 class="font-heading text-3xl md:text-4xl text-[#1C1713] mb-8">Tu experiencia en <span class="text-[#D4AD65] italic">{heroTitle}</span> comienza con una <span class="text-[#D4AD65] italic">decisión</span>.</h2>
          <a 
            href="/contacto" 
            class="group/cta relative overflow-hidden inline-flex items-center gap-4 font-label text-[10px] md:text-xs uppercase tracking-widest font-medium text-[#FAF9F6] bg-[#1C1713] px-8 py-4 transition-all duration-500 shadow-md"
          >
            <span class="absolute inset-0 bg-[#D4AD65] transform translate-y-[100%] group-hover/cta:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)]"></span>
            <span class="relative z-10 flex items-center gap-4 transition-colors duration-500">
              Diseña tu experiencia
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover/cta:translate-x-1 transition-transform duration-500"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </span>
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style is:global>
  /* Encapsular estilos de Swiper bajo el ID de lugares para evitar contaminación global */
  #lugares .placesSwiper .swiper-pagination-progressbar {
    background: rgba(255, 255, 255, 0.1) !important;
    height: 2px !important;
    border-radius: 0 !important;
  }
  #lugares .placesSwiper .swiper-pagination-progressbar-fill {
    background: #D4AD65 !important;
    border-radius: 0 !important;
  }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination } from 'swiper/modules';
    import 'swiper/css';
    import 'swiper/css/pagination';

    function initPlacesSwiper() {
        const target = document.querySelector('.placesSwiper');
        if (!target) return;
        
        new Swiper('.placesSwiper', {
            modules: [Navigation, Pagination],
            slidesPerView: 1.15,
            spaceBetween: 16,
            grabCursor: true,
            watchSlidesProgress: true,
            pagination: {
                el: '.places-swiper-pagination',
                type: 'progressbar',
            },
            navigation: {
                nextEl: '#swiperNext',
                prevEl: '#swiperPrev',
            },
            breakpoints: {
                768: {
                    slidesPerView: 2.3,
                    spaceBetween: 24,
                },
                1024: {
                    slidesPerView: 3,
                    spaceBetween: 32,
                }
            }
        });
    }

    function initExperiencesSlider() {
        let currentIndex = 1;
        const track = document.getElementById('experiences-carousel-track');
        const slides = document.querySelectorAll('.experience-slide');
        const progressBar = document.getElementById('experience-progress-bar');
        const counter = document.getElementById('experience-counter');
        const prevBtn = document.getElementById('prev-experience');
        const nextBtn = document.getElementById('next-experience');
        
        if (!track || !slides.length) return;
        
        function updateCarousel() {
          const activeSlide = slides[currentIndex] as HTMLElement;
          if (!activeSlide) return;
          const parentEl = track.parentElement;
          if (!parentEl) return;
          const containerWidth = parentEl.clientWidth;
          const slideWidth = activeSlide.clientWidth;
          const slideOffsetLeft = activeSlide.offsetLeft;
          
          // Calcular el desfase para centrar la diapositiva activa
          const translateVal = (containerWidth / 2) - (slideOffsetLeft + slideWidth / 2);
          track.style.transform = `translateX(${translateVal}px)`;
          
          // Actualizar escalas y opacidades
          slides.forEach((slide, idx) => {
            const imgs = slide.querySelectorAll('.gallery-image');
            if (idx === currentIndex) {
              slide.classList.add('scale-100', 'opacity-100', 'z-10');
              slide.classList.remove('scale-90', 'opacity-40', 'z-0');
              imgs.forEach(img => img.classList.add('scale-105'));
            } else {
              slide.classList.remove('scale-100', 'opacity-100', 'z-10');
              slide.classList.add('scale-90', 'opacity-40', 'z-0');
              imgs.forEach(img => img.classList.remove('scale-105'));
            }
          });
          
          // Actualizar barra de progreso y contador
          if (progressBar) {
            progressBar.style.width = `${((currentIndex + 1) / slides.length) * 100}%`;
          }
          if (counter) {
            counter.textContent = `${currentIndex + 1} / ${slides.length}`;
          }
        }
        
        // Controles de botones
        prevBtn?.addEventListener('click', () => {
          currentIndex = (currentIndex - 1 + slides.length) % slides.length;
          updateCarousel();
        });
        
        nextBtn?.addEventListener('click', () => {
          currentIndex = (currentIndex + 1) % slides.length;
          updateCarousel();
        });
        
        // Permitir clic directo en la tarjeta
        slides.forEach((slide, index) => {
          slide.addEventListener('click', () => {
            currentIndex = index;
            updateCarousel();
          });
        });
        
        // Script para rotar la galería de imágenes dentro de cada tarjeta
        slides.forEach(slide => {
          const images = slide.querySelectorAll('.gallery-image');
          if (images.length <= 1) return;
          
          let imgIndex = 0;
          setInterval(() => {
            images[imgIndex].classList.add('opacity-0');
            images[imgIndex].classList.remove('opacity-100');
            imgIndex = (imgIndex + 1) % images.length;
            images[imgIndex].classList.remove('opacity-0');
            images[imgIndex].classList.add('opacity-100');
          }, 4000 + Math.random() * 1500); // Tiempos desfasados naturalmente
        });
        
        // Inicializar y recalcular en caso de resize
        updateCarousel();
        window.addEventListener('resize', updateCarousel);
    }

    function initAll() {
        initPlacesSwiper();
        initExperiencesSlider();
    }

    // Inicializar de forma limpia
    if (document.readyState === 'loading') {
        document.addEventListener("DOMContentLoaded", initAll);
    } else {
        initAll();
    }
</script>
