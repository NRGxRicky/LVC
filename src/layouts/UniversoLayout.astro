    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .fade-in-stagger.animate-in {
    opacity: 1;
    transform: translateY(0);
  }
</style>

